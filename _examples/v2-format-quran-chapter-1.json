  "verses": [
    {
      "idx": 1,
      "global_idx": 1,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
      },
      "translations": {
        "en.qarai": "In the Name of Allah, the All-beneficent, the All-merciful.",
        "fa.makarem": "به نام خداوند بخشنده بخشایشگر"
      }
    },
    {
      "idx": 2,
      "global_idx": 2,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ"
      },
      "translations": {
        "en.qarai": "All praise belongs to Allah, Lord of all the worlds,",
        "fa.makarem": "ستایش مخصوص خداوندی است که پروردگار جهانیان است"
      }
    },
    {
      "idx": 3,
      "global_idx": 3,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "الرَّحْمَٰنِ الرَّحِيمِ"
      },
      "translations": {
        "en.qarai": "the All-beneficent, the All-merciful,",
        "fa.makarem": "بخشنده بخشایشگر"
      }
    },
    {
      "idx": 4,
      "global_idx": 4,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "مَالِكِ يَوْمِ الدِّينِ"
      },
      "translations": {
        "en.qarai": "Master of the Day of Retribution.",
        "fa.makarem": "مالک روز جزا"
      }
    },
    {
      "idx": 5,
      "global_idx": 5,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ"
      },
      "translations": {
        "en.qarai": "You [alone] do we worship, and to You [alone] do we turn for help.",
        "fa.makarem": "تنها تو را می‌پرستیم و تنها از تو یاری می‌جوییم"
      }
    },
    {
      "idx": 6,
      "global_idx": 6,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ"
      },
      "translations": {
        "en.qarai": "Guide us on the straight path,",
        "fa.makarem": "ما را به راه راست هدایت کن"
      }
    },
    {
      "idx": 7,
      "global_idx": 7,
      "juz": 1,
      "manzil": 1,
      "page": 1,
      "ruku": 1,
      "text": {
        "ar": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ"
      },
      "translations": {
        "en.qarai": "the path of those whom You have blessed—such as have not incurred Your wrath, nor are astray.",
        "fa.makarem": "راه کسانی که نعمتشان دادی، نه خشم‌گرفتگان و نه گمراهان"
      }
    }
  ]
}
