        "en.sahih": [
          "And increased therein the corruption."
        ],
        "en.sarwar": [
          "and spread much corruption in the land."
        ],
        "en.shakir": [
          "So they made great mischief therein?"
        ],
        "en.transliteration": [
          "Faaktharoo feeh<u>a</u> alfas<u>a</u>d<b>a</b>"
        ],
        "en.wahiduddin": [
