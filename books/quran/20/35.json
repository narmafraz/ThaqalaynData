      "text": [
        "إِنَّکَ‌ کُنْتَ‌ بِنَا بَصِيراً"
      ],
      "translations": {
        "en.ahmedali": [
          "Surely You know us well.\""
        ],
        "en.ahmedraza": [
          "“Indeed You see us.”"
        ],
        "en.arberry": [
          "Surely Thou seest into us.'"
        ],
        "en.daryabadi": [
          "Verily Thou! Thou art of us ever a Beholder."
        ],
        "en.hilali": [
          "\"Verily! You are of us Ever a Well-Seer.\""
        ],
        "en.itani": [
          "You are always watching over us.”"
        ],
        "en.maududi": [
          "Verily, You have always watched over us.\""
        ],
        "en.mubarakpuri": [
          "\"Verily, You are ever seeing us.\""
        ],
        "en.pickthall": [
          "Lo! Thou art ever Seeing us."
        ],
        "en.qarai": [
          "Indeed You see us best.’"
        ],
        "en.qaribullah": [
          "You are surely seeing us'"
        ],
        "en.sahih": [
          "Indeed, You are of us ever Seeing.\""
        ],
        "en.sarwar": [
          "You are Well Aware of our situation.\""
        ],
        "en.shakir": [
          "Surely, Thou art seeing us."
        ],
        "en.transliteration": [
          "Innaka kunta bin<u>a</u> ba<u>s</u>eer<u>a</u><b>n</b>"
        ],
        "en.wahiduddin": [
          "You are surely watching over us."
        ],
        "en.yusufali": [
          "\"For Thou art He that (ever) regardeth us.\""
        ],
        "fa.ansarian": [
          "بی تردید تو به ما بینایی."
        ],
        "fa.ayati": [
          "كه تو بر حال ما آگاه بوده‌اى."
        ],
        "fa.bahrampour": [
