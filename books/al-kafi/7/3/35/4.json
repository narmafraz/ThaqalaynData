      "relations": null,
      "text": [
        " أَدْنَى مَا يُقْطَعُ فِيهِ يَدُ السَّارِقِ خُمُسُ دِينَارٍ ."
      ],
      "translations": {
        "en.hubeali": [
          "Ali, from Muhammad Bin Isa, from Yunus, from Muhammad Bin Humran, and from his father, from Ibn Abu Umeyr, from Jameel Bin Darraj, altogether from Muhammad Bin Muslim, ",
          "Abu Ja’far<sup>asws</sup> has said: ‘The lowest of that with regards to which the hand of the thief would be cut, is five Dinars’."
        ]
      }
