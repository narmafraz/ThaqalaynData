      "relations": null,
      "text": [
        " قَالَ رَسُولُ اللَّهِ ( صلى الله عليه وآله ) لَا قَطْعَ فِي ثَمَرٍ وَ لَا كَثَرٍ وَ الْكَثَرُ شَحْمُ النَّخْلِ ."
      ],
      "translations": {
        "en.hubeali": [
          "Ali Bin Ibrahim, from his father, from Al Nowfaly, from Al Sakuny, ",
          "(It has been narrated) from Abu Abdullah<sup>asws</sup> having said: ‘Rasool-Allah<sup>saww</sup> said: ‘There would be no cutting regarding a fruit, nor a <span class=\"iTxt\">Kasar</span>, and the <span class=\"iTxt\">Kasar</span> is a sap of the palm tree’."
        ]
      }
