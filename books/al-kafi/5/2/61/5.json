      "part_type": "Hadith",
      "path": "/books/al-kafi:5:2:61:5",
      "relations": null,
      "text": [
        " نَهَى رَسُولُ اللَّهِ ( صلى الله عليه وآله ) عَنْ أَنْ يُشَابَ اللَّبَنُ بِالْمَاءِ لِلْبَيْعِ ."
      ],
      "translations": {
        "en.hubeali": [
          "Ali Bin Ibrahim, from his father, from Ibn Abu Umeyr, from Al Nowfaly, from Al Sakuny, ",
          "(It has been narrated) from Abu Abdullah<sup>asws</sup> having said: ‘Rasool-Allah<sup>azwj</sup> forbade from the milk be mixed with the water for the selling’."
        ],
        "en.sarwar": [
          "5. Ali ibn Ibrahim has narrated from his father from ibn abu ‘Umayr from al-Nawfaliy from al-Sakuniy, who has said the following: “Abu ‘Abd Allah, ‘Alayhi al-Salam, has said that the Messenger of Allah, O Allah, grant compensation to Muhammad and his family worthy of their services to Your cause, prohibited mixing of milk with water to sell.’” "
        ]
      }
    }
