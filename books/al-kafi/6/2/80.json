              "text": " عَنْ "
            },
            {
              "kind": "plain",
              "text": "أَبِي عَبْدِ اللَّهِ ( عليه السلام ) أَنَّهُ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
