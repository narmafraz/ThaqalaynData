      "part_type": "Hadith",
      "path": "/books/al-kafi:2:1:49:1",
      "text": [
        " إِنَّ أَكْمَلَ الْمُؤْمِنِينَ إِيمَاناً أَحْسَنُهُمْ خُلُقاً ."
