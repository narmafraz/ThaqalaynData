      "relations": null,
      "text": [
        " قَالَ التَّقِيَّةُ تُرْسُ اللَّهِ بَيْنَهُ وَ بَيْنَ خَلْقِهِ ."
      ],
      "translations": {
        "en.hubeali": [
          "Ali Bin Ibrahim, from Muhammad Bin Isa, from Yunus, from Ibn Muskan, from Hareyz, ",
          "(It has been narrated) from Abu Abdullah<sup>asws</sup> having said: ‘The dissimulation (<span class=\"iTxt\">Taqiyya</span>) is a shield of Allah<sup>azwj</sup>, between Him<sup>azwj</sup> and His<sup>azwj</sup> creatures’."
        ],
        "en.sarwar": [
          "19. Ali ibn Ibrahim has narrated from Muhammad ibn ‘Isa from Yunus from ibn Muskan from Hariz from abu ‘Abd Allah (a.s.) who has said the following: “ Al-Taqiyyah is a shield of Allah between Allah (His punishing) and His creatures.” "
        ]
      }
