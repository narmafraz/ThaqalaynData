        " مَنْ عَرَفَ اخْتِلَافَ النَّاسِ فَلَيْسَ بِمُسْتَضْعَفٍ ."
      ],
      "translations": {
        "en.hubeali": [
          "Ali Bin Ibrahim, from his father, from Ibn Abu Umeyr, from Abu Al Magra’a, from Abu Baseer, ",
          "(It has been narrated) from Abu Abdullah<sup>asws</sup> having said: ‘The one who recognises the differing of the people, so he is not a weak one (of understanding)’."
        ],
        "en.sarwar": [
          "10. Ali ibn Ibrahim has narrated from his father from ibn abu ‘Umayr from abu al- Maghra’ from abu Basir from abu ‘Abd Allah (a.s.) who has said the following: “Whoever knows the differences among people is not a feeble- minded person.” "
        ]
      }
