      {
        "inline": {
          "part_type": "Heading",
          "text": [
            "تَمَّ كِتَابُ الصَّوْمِ وَ يَتْلُوهُ كِتَابُ الْحَجِّ وَ الْحَمْدُ لِلَّهِ وَحْدَهُ وَ صَلَّى اللَّهُ عَلَى مَنْ لَا نَبِيَّ بَعْدَهُ وَ آلِهِ الطَّيِّبِينَ الطَّاهِرِينَ ."
          ],
          "translations": {
            "en.hubeali": [
              "The Book of Fasts is completed and it will be followed by the Book of Hajj. And the Praise is for Allah<sup>azwj</sup> Alone, and may Allah<sup>azwj</sup> Send Blessings upon the one<sup>saww</sup> after whom there is no Prophet, and his<sup>saww</sup> Purified Progeny<sup>asws</sup>."
            ]
          }
        },
        "part_type": "Heading"
      }
