      "translations": {
        "en.hubeali": [
          "<a id=\"_Toc492473393\">H 14715</a> – Ja’far Bin Basheer, from Ruzeyq, who has reported the following:",
          "<span class=\"first-chapter-phrase\"><span class=\"first-in-chapter character-a\">A</span>bu Abdullah</span><sup>asws</sup> has said: ‘Lightning does not occur at all in the darkness of the night or the light of the day unless it is raining’."
        ],
        "en.sarwar": [
