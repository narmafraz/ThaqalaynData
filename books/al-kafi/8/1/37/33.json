      "translations": {
        "en.hubeali": [
          "<a id=\"_Toc492473308\">H 14634</a> – Sahl Bin Ziyad, from Bakr Bin Saleh, from Ibn Sinan, from Amro Bin Shimr, who has narrated the following:",
          "<span class=\"first-chapter-phrase\"><span class=\"first-in-chapter character-a\">A</span>bu Abdullah</span><sup>asws</sup> said: ‘The wisdom is the objective of the believer, so wherever one of you finds his objective, so he should take it’."
        ],
        "en.sarwar": [
          "186. Sahl Bin Ziyad, from Bakr Bin Saleh, from Ibn Sinan, from Amro Bin Shimr, who has narrated the following: Abu Abdullah (a.s.) said: ‘The wisdom is the objective of the believer, so wherever one of you finds his objective, so he should take it’."
        ]
