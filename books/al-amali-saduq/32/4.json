        "isnad_matn": {
          "has_chain": true,
          "isnad_ar": "حَدَّثَنَا مُحَمَّدُ بْنُ مُوسَى بْنِ الْمُتَوَكِّلِ قَالَ: حَدَّثَنَا عَلِيُّ بْنُ الْحُسَيْنِ السَّعْدَآبَادِيُّ عَنْ أَحْمَدَ بْنِ مُحَمَّدِ بْنِ خَالِدٍ عَنْ أَبِيهِ عَنْ أَبِي أَحْمَدَ مُحَمَّدِ بْنِ زِيَادٍ الْأَزْدِيِّ عَنْ مَالِكِ بْنِ أَنَسٍ قَالَ:",
