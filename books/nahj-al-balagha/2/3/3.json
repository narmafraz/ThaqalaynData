      "text": [
        "بَلَغَنِي أَنَّكَ ابْتَعْتَ دَاراً بِثَمانِينَ دِينَاراً، وَكَتَبْتَ لَهَا كِتَاباً، وَأَشْهَدْتَ فِيهِ شُهُوداً؟"
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "I have come to know that you have purchased a house for eighty Dinars, and that you have written a document for it and put witnessing on it?"
        ]
      }
    }
