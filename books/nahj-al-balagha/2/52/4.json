      "text": [
        "وَصَلُّوا بِهِمُ الْمَغْرِبَ حِينَ يُفْطِرُ الصَّائِمُ، وَيَدْفَعُ الْحَاجُّ إِلَى مِنًى."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Say the maghrib (sunset) prayers when he who is fasting ends the fast and the pilgrim rushes (from ‘Arafat) to Minā."
        ]
      }
    }
