      "text": [
        "أَمَّا بَعْدُ، فَصَلُّوا بَالنَّاسِ الظُّهْرَ حَتَّى تَفِيءَ الشَّمْسُ مِنْ مَرْبِضِ الْعَنْزِ."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Now, say the ẓuhr (noon) prayers with the people when the shade of the wall of the goats’ pen is equal to the wall."
        ]
      }
    }
