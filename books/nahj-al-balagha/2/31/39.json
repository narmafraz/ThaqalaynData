      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "إِسْتَوْدِعِ اللهَ دِينَكَ وَدُنْيَاكَ، وَاسْأَلْهُ خَيْرَ الْقَضَاءِ لَكَ فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/nahj-al-balagha:2:31:39",
      "source_url": "https://thaqalayn.net/hadith/32/2/31/175",
      "text": [
        " الْعَاجِلَةِ وَالْآجِلَةِ، وَالدُّنْيَا وَالْآخِرَةِ، وَالسَّلَامُ."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Place your religion and your world at Allah’s disposal and beg Him to ordain the best for you in respect of the near and the far, this world and the next; and that is an end to the matter."
        ]
      }
    },
    "verse_translations": [
      "en.sayed-ali-raza"
    ]
