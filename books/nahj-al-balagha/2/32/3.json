      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "فَاتَّقِ اللهَ يَا مُعَاوِيَةُ فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/nahj-al-balagha:2:32:3",
      "source_url": "https://thaqalayn.net/hadith/32/2/32/178",
      "text": [
        " نَفْسِكَ، وَجَاذِبِ الشَّيْطَانَ قيَادَكَ، فَإِنَّ الدُّنْيَا مُنْقَطِعَةٌ عَنْكَ، وَالْآخِرَةَ قَرِيبَةٌ مِنْكَ، وَالسَّلَامُ."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Therefore, O’ Mu‘āwiyah, fear Allāh about yourself and take away your rein from Satan, since this world is shortly to be cut off from you and the next world is near you; and that is an end to the matter."
        ]
      }
    },
    "verse_translations": [
      "en.sayed-ali-raza"
    ]
