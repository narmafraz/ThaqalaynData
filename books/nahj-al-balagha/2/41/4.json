      "text": [
        "فَسُبْحَانَ اللهِ! أَمَا تُؤْمِنُ بِالْمَعَادِ؟ أَوَ مَا تَخَافُ نِقَاشَ الْحِسَابِ؟"
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Glory be to Allāh! Do you not believe in the Day of judgement, or do you not fear the exaction of account?"
        ]
