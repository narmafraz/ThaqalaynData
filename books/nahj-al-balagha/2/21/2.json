    "verse": {
      "index": 1268,
      "local_index": 2,
      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "فدَعِ الْإِسْرَافَ مُقْتَصِداً، وَاذْكُرْ فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/nahj-al-balagha:2:21:2",
      "source_url": "https://thaqalayn.net/hadith/32/2/21/77",
      "text": [
        " الْيَوْمِ غَداً، وَأَمْسِكْ مِنَ الْمَالِ بِقَدْرِ ضَرُورَتِكَ، وَقَدِّمِ الْفَضْلَ لِيَوْمِ حَاجَتِكَ."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Give up lavishness and be moderate. Every day remember the coming day. Hold back from the funds what you need and send forward the balance for the day of your need."
        ]
      }
    },
    "verse_translations": [
      "en.sayed-ali-raza"
    ]
