      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "٣٥. وَقَالَ (عليه ‏السلام): مَنْ أَسْرَعَ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "النَّاسِ بِمَا يَكْرَهُونَ، قَالُوا"
          },
