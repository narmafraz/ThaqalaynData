    "verses": [
      {
        "index": 1670,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "٤١. وقد روي عنه (عليه ‏السلام) هذا المعنى بلفظ آخر، وهو قوله: قَلبُ الْأَحْمَقِ فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/nahj-al-balagha:3:26:1",
        "source_url": "https://thaqalayn.net/hadith/32/3/41/53",
        "text": [
          " فِيهِ، وَلِسَانُ الْعَاقِلِ فِي قَلْبِهِ."
        ],
        "translations": {
          "en.sayed-ali-raza": [
            "41. This very sense has been related from Amīr al-mu’minīn, peace be upon him, in a different version as follows: The heart of a fool is in his mouth while the tongue of the wise man is in his heart."
          ]
        }
      },
      {
        "index": 1671,
        "local_index": 2,
        "part_type": "Hadith",
        "path": "/books/nahj-al-balagha:3:26:2",
        "source_url": "https://thaqalayn.net/hadith/32/3/41/54",
        "text": [
          "ومعناهما واحد."
        ],
        "translations": {
          "en.sayed-ali-raza": [
            "The meaning of both the sayings (40 and 41) is the same."
          ]
        }
      }
    ]
