      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "٤٧٠. وَسُئِلَ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "plain",
            "text": "التَّوْحِيدِ وَالْعَدْلِ"
          },
          {
