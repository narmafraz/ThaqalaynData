      "text": [
        "بِأَبِي أَنْتَ وَأُمّي! اذْكُرْنَا عِنْدَ رَبِّكَ، وَاجْعَلْنَا مِنْ بَالِكَ!"
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "May my father and my mother die for you; do remember us with Allāh and take care of us."
        ]
      }
    },
