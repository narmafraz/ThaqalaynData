      "text": [
        "وصلى الله على سيدنا محمد النبي الأمي، وعلى آله مصابيح الدجى والعروة الوثقى، وسلم تسليماً كثيراً."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Allāh may bless our master Muḥammad, the Prophet, and his descendants who are lamps of darkness and trustworthy support, and may bestow peace (upon them) abundantly and profusely."
        ]
      }
    },
