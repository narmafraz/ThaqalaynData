      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "فَرَدُّهُ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "اللهِ أَنْ نَحْكُمَ بِكِتَابِهِ، وَرَدُّهُ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "الرَّسُولِ أَنْ نَأْخُذَ بسُنَّتِهِ; فَإِذَا حُكِمَ بِالصِّدْقِ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/nahj-al-balagha:1:125:3",
      "source_url": "https://thaqalayn.net/hadith/32/1/125/3",
      "text": [
        " كِتَابِ اللهِ، فَنَحْنُ أَحَقُّ النَّاسِ بِهِ، وَإِنْ حُكمَ بسُنَّةِ رَسُولِهِ فَنَحْنُ أَوْلاَهُمْ بِهِ."
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "Reference to Allāh means that we decide according to the Qur’ān while reference to the Prophet means that we follow his sunnah. Now therefore, if arbitration were truly done through the Book of Allāh (Qur’ān), we would be the most rightful of all people for the Caliphate; or if it were done by the sunnah of the Holy Prophet, we would be the most preferable of them."
        ]
      }
    },
    "verse_translations": [
      "en.sayed-ali-raza"
    ]
