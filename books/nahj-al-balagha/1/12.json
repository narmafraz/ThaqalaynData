      },
      {
        "index": 69,
        "local_index": 2,
        "part_type": "Hadith",
        "path": "/books/nahj-al-balagha:1:12:2",
        "source_url": "https://thaqalayn.net/hadith/32/1/9/2",
        "text": [
          "وقَدْ أَرْعَدُوا وَأبْرَقُوا، وَمَعَ هذَيْنِ الاْمْرَيْنِ الفَشَلُ، وَلَسْنَا نُرْعِدُ حَتَّى نُوقِعَ، وَلا نُسِيلُ حَتَّى نُمْطِر."
        ],
        "translations": {
          "en.sayed-ali-raza": [
            "They [1] thunder like clouds and shone like lightning but despite both these things they exhibited cowardice, while we do not thunder till we pounce upon the foe nor do we show flow (of words) until we have not virtually rained."
          ]
        }
      }
    ]
