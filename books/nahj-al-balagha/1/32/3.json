      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "فَالنَّاسُ عَلَى أَرْبَعَةِ أَصْنَافٍ:"
          },
          {
            "kind": "plain",
            "text": " مِنْهُمْ "
          },
          {
            "kind": "plain",
            "text": "مَنْ لاَ يَمْنَعُهُ الفَسَادَ في"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/nahj-al-balagha:1:32:3",
      "source_url": "https://thaqalayn.net/hadith/32/1/32/3",
      "text": [
        " الاْرْضِ إِلاَّ مَهَانَةُ نَفْسِهِ، وَكَلاَلَةُ حَدِّهِ وَنَضِيضُ وَفْرِهِ"
      ],
      "translations": {
        "en.sayed-ali-raza": [
          "People are of four categories. Among them is one who is prevented from mischief only by his low position, lack of means and paucity of wealth."
        ]
      }
    },
