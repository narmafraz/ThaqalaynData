          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "عُبَيْدِ اَللَّهِ اَلْقُمِّيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/336",
            "text": "عَبْدِ اَللَّهِ بْنِ مَيْمُونٍ اَلْقَدَّاحِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/91",
            "text": "جَعْفَرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِيهِ : «أَنَّ عَلِيّاً عَلَيْهِ اَلسَّلاَمُ كَانَ إِذَا صَلَّى عَلَى مَيِّتٍ يَقْرَأُ بِفَاتِحَةِ اَلْكِتَابِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُصَلِّي عَلَى اَلنَّبِيِّ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ » تَمَامَ اَلْحَدِيثِ . فَالْوَجْهُ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:3:32:14",
      "text": [
        " هَذَا اَلْخَبَرِ مَا قَدَّمْنَاهُ مِنَ اَلتَّقِيَّةِ لِأَنَّا قَدْ دَلَلْنَا عَلَى أَنَّ اَلصَّلاَةَ عَلَى اَلْمَيِّتِ لاَ قِرَاءَةَ فِيهَا بِفَاتِحَةِ اَلْكِتَابِ وَ هَذَا اَلْخَبَرُ وَ اَلَّذِي تَقَدَّمَ مُوَافِقٌ لِبَعْضِ اَلْعَامَّةِ عَلَى مَا قَدَّمْنَا اَلْقَوْلَ فِيهِ فَلاَ يَنْبَغِي أَنْ يَكُونَ عَلَيْهِ اَلْعَمَلُ ."
      ]
    }
