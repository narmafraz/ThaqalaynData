            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ قَائِمٌ ثُمَّ ذَكَرَ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
