            "text": " عَنِ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/623",
            "text": "اَلْحَسَنِ بْنِ مُوسَى اَلْخَشَّابِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/943",
            "text": "غِيَاثِ بْنِ كَلُّوبٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/44",
            "text": "إِسْحَاقَ بْنِ عَمَّارٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/91",
            "text": "جَعْفَرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِيهِ عَلَيْهِمَا اَلسَّلاَمُ : «أَنَّ رَجُلاً قَطَعَ مِنْ بَعْضِ أُذُنِ رَجُلٍ شَيْئاً فَرُفِعَ ذَلِكَ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "عَلِيٍّ عَلَيْهِ اَلسَّلاَمُ فَأَقَادَهُ فَأَخَذَ اَلْآخَرُ مَا قُطِعَ مِنْ أُذُنِهِ فَرَدَّهُ عَلَى أُذُنِهِ بِدَمِهِ فَالْتَحَمَتْ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "بَرَأَتْ فَعَادَ اَلْآخَرُ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "عَلِيٍّ عَلَيْهِ اَلسَّلاَمُ فَاسْتَقَادَهُ فَأَمَرَ بِهَا فَقُطِعَتْ ثَانِيَةً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أَمَرَ بِهَا فَدُفِنَتْ وَ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
