          },
          {
            "kind": "narrator",
            "path": "/people/narrators/90",
            "text": "مُحَمَّدُ بْنُ اَلْحَسَنِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/539",
            "text": "عَبْدِ اَللَّهِ بْنِ اَلْحَسَنِ اَلْعَلَوِيِّ"
          },
          {
            "kind": "plain",
            "text": " جَمِيعاً عَنِ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/628",
            "text": "اَلْفَتْحِ بْنِ يَزِيدَ اَلْجُرْجَانِيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي اَلْحَسَنِ عَلَيْهِ اَلسَّلاَمُ : «فِي أَرْبَعَةٍ شَهِدُوا عَلَى رَجُلٍ أَنَّهُ زَنَى فَرُجِمَ ثُمَّ رَجَعُوا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "قَالُوا قَدْ وَهَمْنَا يُلْزَمُونَ اَلدِّيَةَ فَإِنْ قَالُوا تَعَمَّدْنَا قَتَلَ أَيَّ اَلْأَرْبَعَةِ شَاءَ وَلِيُّ اَلْمَقْتُولِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "رَدَّ اَلثَّلاَثَةُ ثَلاَثَةَ أَرْبَاعِ اَلدِّيَةِ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "أَوْلِيَاءِ اَلْمَقْتُولِ اَلثَّانِي"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُجْلَدُ اَلثَّلاَثَةُ كُلُّ وَاحِدٍ"
          },
          {
            "kind": "plain",
            "text": " مِنْهُمْ "
          },
          {
            "kind": "plain",
            "text": "ثَمَانِينَ جَلْدَةً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنْ شَاءَ وَلِيُّ اَلْمَقْتُولِ أَنْ يَقْتُلَهُمْ رَدَّ ثَلاَثَ دِيَاتٍ عَلَى أَوْلِيَاءِ اَلشُّهُودِ اَلْأَرْبَعَةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُجْلَدُونَ ثَمَانِينَ كُلُّ وَاحِدٍ"
          },
          {
            "kind": "plain",
            "text": " مِنْهُمْ "
          },
          {
            "kind": "plain",
            "text": "ثُمَّ يَقْتُلُهُمُ اَلْإِمَامُ » وَ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:10:27:13",
      "text": [
        " «فِي رَجُلَيْنِ شَهِدَا عَلَى رَجُلٍ أَنَّهُ سَرَقَ فَقُطِعَ ثُمَّ رَجَعَ وَاحِدٌ مِنْهُمَا فَقَالَ وَهَمْتُ فِي هَذَا وَ لَكِنْ كَانَ غَيْرَهُ يَلْزَمُهُ نِصْفُ دِيَةِ اَلْيَدِ وَ لاَ يُقْبَلُ شَهَادَتُهُ فِي اَلْآخَرِ فَإِنْ رَجَعَا جَمِيعاً فَقَالاَ وَهَمْنَا بَلْ كَانَ اَلسَّارِقُ فُلاَناً يُلْزَمَانِ دِيَةَ اَلْيَدِ وَ لاَ يُقْبَلُ شَهَادَتُهُمَا فِي اَلْآخَرِ فَإِنْ قَالاَ إِنَّا تَعَمَّدْنَا قُطِعَ يَدُ أَحَدِهِمَا بِيَدِ اَلْمَقْطُوعِ وَ يَرُدُّ اَلَّذِي لَمْ يُقْطَعْ رُبُعَ دِيَةِ اَلرَّجُلِ عَلَى أَوْلِيَاءِ اَلْمَقْطُوعِ اَلْيَدِ فَإِنْ قَالَ اَلْمَقْطُوعُ اَلْأَوَّلُ لاَ أَرْضَى أَوْ تُقْطَعَ أَيْدِيهِمَا مَعاً رَدَّ دِيَةَ يَدٍ تَنْقَسِمُ بَيْنَهُمَا وَ يَقْطَعُ أَيْدِيَهُمَا»."
      ]
    }
