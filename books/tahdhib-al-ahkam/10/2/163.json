      "narrator_chain": {
        "parts": [
          {
            "kind": "narrator",
            "path": "/people/narrators/4134",
            "text": "مُحَمَّدُ بْنُ أَحْمَدَ بْنِ يَحْيَى"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/37",
            "text": "بَعْضِ أَصْحَابِهِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/500",
            "text": "إِبْرَاهِيمَ بْنِ مُحَمَّدٍ اَلثَّقَفِيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "إِبْرَاهِيمَ بْنِ يَحْيَى اَلدُّورِيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "هِشَامِ بْنِ بَشِيرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/2034",
            "text": "أَبِي بَشِيرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي رَوْحٍ : أَنَّ اِمْرَأَةً تَشَبَّهَتْ بِأَمَةٍ لِرَجُلٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "ذَلِكَ لَيْلاً فَوَاقَعَهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ يَرَى أَنَّهَا جَارِيَتُهُ فَرُفِعَ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "عُمَرَ فَأَرْسَلَ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "عَلِيٍّ عَلَيْهِ اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " فَقَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:10:2:163",
      "text": [
        " «اِضْرِبِ اَلرَّجُلَ حَدّاً فِي اَلسِّرِّ وَ اِضْرِبِ اَلْمَرْأَةَ حَدّاً فِي اَلْعَلاَنِيَةِ »."
      ]
    }
