          {
            "kind": "plain",
            "text": "رُوِيَ : «أَنَّ هَذِهِ اَلْحَوَائِطَ كَانَتْ وَقْفاً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "كَانَ رَسُولُ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ يَأْخُذُ مِنْهَا مَا يُنْفِقُ عَلَى أَضْيَافِهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَنْ يَمُرُّ بِهِ فَلَمَّا قُبِضَ جَاءَ اَلْعَبَّاسُ يُخَاصِمُ فَاطِمَةَ عَلَيْهَا اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
