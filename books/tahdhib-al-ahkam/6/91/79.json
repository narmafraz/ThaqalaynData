          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/1279",
            "text": "أَبِي عَبْدِ اَللَّهِ اَلرَّازِيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/282",
            "text": "اَلْحَسَنِ بْنِ عَلِيِّ بْنِ أَبِي حَمْزَةَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "مَنْدَلٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/70",
            "text": "عَبْدِ اَلرَّحْمَنِ بْنِ اَلْحَجَّاجِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/178",
            "text": "دَاوُدَ بْنِ فَرْقَدٍ"
          },
          {
            "kind": "plain",
            "text": " جَمِيعاً عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ قَالاَ: سَأَلْنَاهُ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "plain",
            "text": "اَلرَّجُلِ يَكُونُ عِنْدَهُ اَلْمَالُ لِأَيْتَامٍ فَلاَ يُعْطِيهِمْ حَتَّى يَهْلِكُوا فَيَأْتِيهِ وَارِثُهُمْ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "وَكِيلُهُمْ فَيُصَالِحُهُ عَلَى أَنْ يَأْخُذَ بَعْضاً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَدَعَ بَعْضاً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُبْرِئُهُ مِمَّا كَانَ أَ يَبْرَأُ مِنْهُ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
