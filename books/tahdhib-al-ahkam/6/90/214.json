          },
          {
            "kind": "narrator",
            "path": "/people/narrators/66",
            "text": "جَمِيلِ بْنِ دَرَّاجٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "جَمَاعَةٍ مِنْ أَصْحَابِنَا عَنْهُمَا عَلَيْهِمَا اَلسَّلاَمُ قَالاَ: «اَلْغَائِبُ يُقْضَى عَلَيْهِ إِذَا قَامَتْ عَلَيْهِ اَلْبَيِّنَةُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُبَاعُ مَالُهُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُقْضَى عَنْهُ دَيْنُهُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ غَائِبٌ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَكُونُ اَلْغَائِبُ عَلَى حُجَّتِهِ إِذَا قَدِمَ »"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:6:90:214",
      "text": [
        " «وَ لاَ يُدْفَعُ اَلْمَالُ إِلَى اَلَّذِي أَقَامَ اَلْبَيِّنَةَ إِلاَّ بِكُفَلاَءَ ». ,5-(828)35 - عَنْهُ عَنْ أَبِيهِ عَنْ سَعْدِ بْنِ عَبْدِ اَللَّهِ عَنْ أَيُّوبَ بْنِ نُوحٍ عَنْ مُحَمَّدِ بْنِ أَبِي عُمَيْرٍ عَنْ جَمِيلٍ : مِثْلَهُ ."
      ]
