          },
          {
            "kind": "narrator",
            "path": "/people/narrators/29",
            "text": "مُحَمَّدِ بْنِ اَلْحُسَيْنِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/30",
            "text": "صَفْوَانَ بْنِ يَحْيَى"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/306",
            "text": "عَلِيِّ بْنِ إِسْمَاعِيلَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "رَجُلٍ مِنْ أَهْلِ اَلشَّامِ : أَنَّهُ سَأَلَ أَبَا اَلْحَسَنِ اَلرِّضَا عَلَيْهِ اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "رَجُلٍ عَلَيْهِ دَيْنٌ قَدْ فَدَحَهُ (1)"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ يُخَالِطُ اَلنَّاسَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ يُؤْتَمَنُ يَسَعُهُ شِرَاءُ اَلْفُضُولِ مِنَ اَلطَّعَامِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلشَّرَابِ فَهَلْ يَحِلُّ لَهُ أَمْ لاَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هَلْ يَحِلُّ لَهُ أَنْ يَتَضَلَّعَ (2) مِنَ اَلطَّعَامِ أَمْ لاَ يَحِلُّ لَهُ إِلاَّ قَدْرُ مَا يُمْسِكُ بِهِ نَفْسَهُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَبْلُغُهُ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
