            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/23",
            "text": "حَمَّادٍ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/28",
            "text": "اَلْحَلَبِيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ أَنَّ أَبَاهُ حَدَّثَهُ : «أَنَّ أُمَامَةَ بِنْتَ أَبِي اَلْعَاصِ بْنِ اَلرَّبِيعِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أُمُّهَا زَيْنَبُ بِنْتُ رَسُولِ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ فَتَزَوَّجَهَا بَعْدَ عَلِيٍّ عَلَيْهِ اَلسَّلاَمُ اَلْمُغِيرَةُ بْنُ نَوْفَلٍ أَنَّهَا وَجِعَتْ وَجَعاً شَدِيداً حَتَّى اُعْتُقِلَ لِسَانُهَا فَأَتَاهَا اَلْحَسَنُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْحُسَيْنُ عَلَيْهِمَا اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هِيَ لاَ تَسْتَطِيعُ اَلْكَلاَمَ فَجَعَلاَ يَقُولاَنِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْمُغِيرَةُ كَارِهٌ لِمَا يَقُولاَنِ «أَعْتَقْتِ فُلاَناً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أَهْلَهُ » فَتُشِيرُ بِرَأْسِهَا نَعَمْ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/4068",
            "text": "كَذَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "كَذَا فَتُشِيرُ بِرَأْسِهَا نَعَمْ أَمْ لاَ» قُلْتُ فَأَجَازَا ذَلِكَ لَهَا"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
