          },
          {
            "kind": "plain",
            "text": "أَخَوَيْهِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/1003",
            "text": "أَبِيهِمَا"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/164",
            "text": "عَبْدِ اَللَّهِ بْنِ بُكَيْرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/103",
            "text": "عُبَيْدِ بْنِ زُرَارَةَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ : «فِي اَلرَّجُلِ يُطَلِّقُ اِمْرَأَتَهُ تَطْلِيقَتَيْنِ ثُمَّ يُطَلِّقُهَا اَلثَّالِثَةَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ مَرِيضٌ فَهِيَ تَرِثُهُ ». زَوْجِهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لاَ يَرِثُ مِنْهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنْ قُتِلَتْ وَرِثَ مِنْ دِيَتِهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنْ قُتِلَ وَرِثَتْ مِنْ دِيَتِهِ مَا لَمْ يَقْتُلْ أَحَدُهُمَا صَاحِبَهُ » . فَلاَ يُنَافِي هَذَا اَلْحَدِيثُ اَلْخَبَرَيْنِ اَلْأَوَّلَيْنِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "غَيْرَهُمَا مِنَ اَلْأَخْبَارِ اَلْمُتَقَدِّمَةِ مِنْ أَنَّهَا تَرِثُهُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنْ كَانَتِ اَلتَّطْلِيقَةُ ثَالِثَةً لِأَنَّ هَذَا اَلْخَبَرَ مَحْمُولٌ عَلَى أَنَّهُ إِذَا طَلَّقَهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ صَحِيحٌ ثُمَّ تُوُفِّيَ بَعْدَ ذَلِكَ لِأَنَّ مَنْ طَلَّقَ اِمْرَأَتَهُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ صَحِيحٌ فَإِنَّمَا تَثْبُتُ اَلْمُوَارَثَةُ بَيْنَهُمَا مَا دَامَ لَهُ عَلَيْهَا رَجْعَةٌ فَإِنْ لَمْ يَكُنْ لَهُ عَلَيْهَا رَجْعَةٌ فَلاَ تَوَارُثَ بَيْنَهُمَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْمَرِيضُ مَخْصُوصٌ مِنْ بَيْنِ ذَلِكَ بِثُبُوتِ اَلْمُوَارَثَةِ بَيْنَهُمَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنِ اِنْقَطَعَتِ اَلْعِصْمَةُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اِنْتَفَتِ اَلْمُرَاجَعَةُ كَمَا أَنَّهُ مَخْصُوصٌ بِأَنْ تَرِثَهُ مَا بَيْنَهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "بَيْنَ سَنَةٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَيْسَ ذَلِكَ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:8:3:187",
      "text": [
        " غَيْرِهِ وَ قَدْ قَدَّمْنَا مَا يَدُلُّ عَلَى ذَلِكَ ."
      ]
    }
