            "kind": "plain",
            "text": "فَأَمَّا مَا رَوَاهُ - أَحْمَدُ بْنُ مُحَمَّدِ بْنِ عِيسَى"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/21",
            "text": "اَلْحُسَيْنِ بْنِ سَعِيدٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/30",
            "text": "صَفْوَانَ بْنِ يَحْيَى"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "مُوسَى"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/18",
            "text": "زُرَارَةَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ : «أَنَّ اَلرَّجُلَ إِذَا ظَاهَرَ مِنِ اِمْرَأَتِهِ ثُمَّ غَشِيَهَا قَبْلَ أَنْ يُكَفِّرَ فَإِنَّمَا عَلَيْهِ كَفَّارَةٌ وَاحِدَةٌ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَكُفُّ عَنْهَا حَتَّى يُكَفِّرَ». فَيَحْتَمِلُ أَيْضاً مَا قَدَّمْنَاهُ مِنْ أَنَّهُ يَكُونُ مُوَاقَعَتُهُ لَهَا جَهْلاً أَوْ نِسْيَاناً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَحْتَمِلُ أَيْضاً أَنْ يَكُونَ هَذَا مَخْصُوصاً بِمَنْ كَانَ ظِهَارُهُ مَشْرُوطاً بِالْمُوَاقَعَةِ لِأَنَّ مَنْ كَانَ كَذَلِكَ لاَ يَجِبُ عَلَيْهِ اَلْكَفَّارَةُ إِلاَّ بَعْدَ اَلْمُوَاقَعَةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "قَدْ قَدَّمْنَاهُ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
