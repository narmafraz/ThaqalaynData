        "path": "/books/tahdhib-al-ahkam:1:8:1",
        "text": [
          "الشيخ الأجل أبو العباس أحمد بن عليّ بن أحمد بن العباس النجاشيّ"
        ]
      },
      {
        "index": 63,
        "local_index": 2,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:2",
        "text": [
          "الفاضل الفقيه أحمد بن عليّ بن قدامة."
        ]
      },
      {
        "index": 64,
        "local_index": 3,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:3",
        "text": [
          "الثقة العين جعفر بن محمّد بن أحمد بن العباس الدوريستي."
        ]
      },
      {
        "index": 65,
        "local_index": 4,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:4",
        "text": [
          "الحسين بن علي النيشابوري."
        ]
      },
      {
        "index": 66,
        "local_index": 5,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:5",
        "text": [
          "الشيخ الفقيه أبو يعلى سلار بن عبد العزيز الديلميّ ."
        ]
      },
      {
        "index": 67,
        "local_index": 6,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:6",
        "text": [
          "أبو الحسن عليّ بن محمّد بن عبد الرحمن الفارسيّ ."
        ]
      },
      {
        "index": 68,
        "local_index": 7,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:7",
        "text": [
          "الشريف السيّد المرتضى علم الهدى عليّ بن الحسين بن موسى الموسوي."
        ]
      },
      {
        "index": 69,
        "local_index": 8,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:8",
        "text": [
          "أبو الفوارس بن عليّ بن محمّد بن عبد الرحمن الفارسيّ المتقدم ذكره."
        ]
      },
      {
        "index": 70,
        "local_index": 9,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:9",
        "text": [
          "الشريف السيّد الرضي محمّد بن الحسين بن موسى الموسوي."
        ]
      },
      {
        "index": 71,
        "local_index": 10,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:10",
        "text": [
          "شيخ الطائفة محمّد بن الحسن الطوسيّ ."
        ]
      },
      {
        "index": 72,
        "local_index": 11,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:11",
        "text": [
          "أبو يعلى محمّد بن الحسن بن حمزة الجعفري صهره و خليفته و الجالس في حياته في مجلسه."
        ]
      },
      {
        "index": 73,
        "local_index": 12,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:12",
        "text": [
          "أبو الفتح الفقيه القاضي محمّد بن علي الكراجكيّ المتوفّى سنة 449."
        ]
      },
      {
        "index": 74,
        "local_index": 13,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:13",
        "text": [
          "أبو محمّد أخو عليّ بن محمّد الفارسيّ المتقدم ذكره."
        ]
      },
      {
        "index": 75,
        "local_index": 14,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:14",
        "text": [
          "الشيخ الثقة أبو الفرج المظفر بن عليّ بن الحسين الحمداني من سفراء الامام الحجة عجل اللّه فرجه."
        ]
      },
      {
        "index": 76,
        "local_index": 15,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:15",
        "text": [
          "الشريف أبو الوفاء المحمدي الموصلي."
        ]
      },
      {
        "index": 77,
        "local_index": 16,
        "part_type": "Hadith",
        "path": "/books/tahdhib-al-ahkam:1:8:16",
        "text": [
          "أبو شجاع تاج الملّة - عضد الدولة - علي بن الحسن بن بويه الديلميّ أخذ عنه الفقه على مذهب الإماميّة(1)"
        ]
      }
    ]
  },
