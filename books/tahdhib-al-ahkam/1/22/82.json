          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/40",
            "text": "حَرِيزٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/18",
            "text": "زُرَارَةَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ : «أَنَّ أَسْمَاءَ بِنْتَ عُمَيْسٍ نُفِسَتْ - بِمُحَمَّدِ بْنِ أَبِي بَكْرٍ فَأَمَرَهَا رَسُولُ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ حِينَ أَرَادَتِ اَلْإِحْرَامَ بِذِي اَلْحُلَيْفَةِ أَنْ تَحْتَشِيَ بِالْكُرْسُفِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْخِرَقِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "تُهِلَّ بِالْحَجِّ فَلَمَّا قَدِمُوا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "نَسَكُوا اَلْمَنَاسِكَ فَأَتَتْ لَهَا ثَمَانِيَ عَشْرَةَ لَيْلَةً فَأَمَرَهَا رَسُولُ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ أَنْ تَطُوفَ بِالْبَيْتِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "تُصَلِّيَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يَنْقَطِعْ عَنْهَا اَلدَّمُ فَفَعَلَتْ ذَلِكَ »."
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هَذَا اَلْحَدِيثُ يُبَيِّنُ عَمَّا قَدَّمْنَا ذِكْرَهُ لِأَنَّهُ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:1:22:82",
      "text": [
        " فَأَتَتْ لَهَا ثَمَانِيَ عَشْرَةَ لَيْلَةً وَ لَمْ يَقُلْ إِنَّهُ أَمَرَهَا بِالْقُعُودِ ثَمَانِيَ عَشْرَةَ لَيْلَةً وَ إِنَّمَا أَمَرَهَا بَعْدَ اَلثَّمَانِيَ عَشْرَةَ لَيْلَةً بِالصَّلاَةِ ."
      ]
    }
