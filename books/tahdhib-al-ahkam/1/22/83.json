            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ حِينَ أَرَادَتِ اَلْإِحْرَامَ مِنْ ذِي اَلْحُلَيْفَةِ أَنْ تَغْتَسِلَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "تَحْتَشِيَ بِالْكُرْسُفِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "تُهِلَّ بِالْحَجِّ فَلَمَّا قَدِمُوا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "نَسَكُوا اَلْمَنَاسِكَ سَأَلَتِ اَلنَّبِيَّ عَلَيْهِ اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "plain",
            "text": "اَلطَّوَافِ بِالْبَيْتِ"
