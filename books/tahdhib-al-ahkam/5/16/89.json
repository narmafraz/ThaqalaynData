          },
          {
            "kind": "narrator",
            "path": "/people/narrators/7",
            "text": "اِبْنِ أَبِي عُمَيْرٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/66",
            "text": "جَمِيلِ بْنِ دَرَّاجٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/38",
            "text": "حَمَّادِ بْنِ عِيسَى"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "جَمَاعَةٍ مِمَّنْ رَوَيْنَا عَنْهُ مِنْ أَصْحَابِنَا"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/191",
            "text": "أَبِي جَعْفَرٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِمَا اَلسَّلاَمُ أَنَّهُمَا قَالاَ: «إِنَّ رَسُولَ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ أَمَرَ أَنْ يُؤْخَذَ مِنْ كُلِّ بَدَنَةٍ بَضْعَةٌ فَأَمَرَ بِهَا رَسُولُ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ فَطُبِخَتْ فَأَكَلَ هُوَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "عَلِيٌّ عَلَيْهِ اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "حَسَوَا مِنَ اَلْمَرَقِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "قَدْ كَانَ اَلنَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ أَشْرَكَهُ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
