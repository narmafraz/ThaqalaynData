          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/336",
            "text": "عَبْدِ اَللَّهِ بْنِ مَيْمُونٍ اَلْقَدَّاحِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ : «أَنَّ عَلِيَّ بْنَ اَلْحُسَيْنِ عَلَيْهِمَا اَلسَّلاَمُ كَانَ يَتَزَوَّجُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "هُوَ يَتَعَرَّقُ عَرْقاً يَأْكُلُ فَمَا يَزِيدُ عَلَى أَنْ يَقُولَ «اَلْحَمْدُ لِلَّهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "صَلَّى اَللَّهُ عَلَى مُحَمَّدٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَسْتَغْفِرُ اَللَّهَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "قَدْ زَوَّجْنَاكَ عَلَى شَرْطِ اَللَّهِ » ثُمَّ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
