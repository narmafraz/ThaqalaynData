          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "جَعْفَرِ بْنِ مُحَمَّدِ بْنِ عَلِيٍّ اَلْأَشْعَرِيِّ"
