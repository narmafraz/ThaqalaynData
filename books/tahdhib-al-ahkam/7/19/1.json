          },
          {
            "kind": "narrator",
            "path": "/people/narrators/318",
            "text": "مُحَمَّدِ بْنِ أَبِي عُمَيْرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/54",
            "text": "حَمَّادِ بْنِ عُثْمَانَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/711",
            "text": "عُبَيْدِ اَللَّهِ اَلْحَلَبِيِّ"
          },
          {
            "kind": "plain",
            "text": " جَمِيعاً عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ أَنَّ أَبَاهُ حَدَّثَهُ : «أَنَّ رَسُولَ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ أَعْطَى خَيْبَرَ بِالنِّصْفِ أَرْضَهَا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "نَخْلَهَا فَلَمَّا أَدْرَكَتِ اَلثَّمَرَةُ بَعَثَ عَبْدَ اَللَّهِ بْنَ رَوَاحَةَ فَقَوَّمَ عَلَيْهِمْ قِيمَةً"
          },
          {
            "kind": "plain",
            "text": " فَقَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:7:19:1",
      "text": [
        " «إِمَّا أَنْ تَأْخُذُوهُ وَ تُعْطُونَ نِصْفَ اَلثَّمَرَةِ وَ إِمَّا أَنْ أُعْطِيَكُمْ نِصْفَ اَلثَّمَرَةِ وَ آخُذَهُ »» فَقَالَ بِهَذَا قَامَتِ اَلسَّمَاوَاتُ وَ اَلْأَرْضُ ."
      ]
    }
