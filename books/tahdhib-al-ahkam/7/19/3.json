          },
          {
            "kind": "narrator",
            "path": "/people/narrators/344",
            "text": "أَبِي اَلرَّبِيعِ اَلشَّامِيِّ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ : أَنَّهُ سُئِلَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "رَجُلٍ يَزْرَعُ أَرْضَ رَجُلٍ آخَرَ فَيَشْتَرِطُ عَلَيْهِ ثُلُثاً لِلْبَذْرِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "ثُلُثاً لِلْبَقَرِ"
          },
          {
            "kind": "plain",
            "text": " فَقَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:7:19:3",
      "text": [
        " «لاَ يَنْبَغِي أَنْ يُسَمِّيَ بَذْراً وَ لاَ بَقَراً وَ لَكِنْ يَقُولُ لِصَاحِبِ اَلْأَرْضِ أَزْرَعُ فِي أَرْضِكَ وَ لَكَ مِنْهَا كَذَا وَ كَذَا نِصْفٌ أَوْ ثُلُثٌ أَوْ مَا كَانَ مِنْ شَرْطٍ وَ لاَ يُسَمِّي بَذْراً وَ لاَ بَقَراً فَإِنَّمَا يُحَرِّمُ اَلْكَلاَمُ »."
      ]
    }
