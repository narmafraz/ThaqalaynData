          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/1843",
            "text": "إِبْرَاهِيمَ بْنِ هَاشِمٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/106",
            "text": "إِسْمَاعِيلَ بْنِ مَرَّارٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "عَبْدِ اَلْجَبَّارِ بْنِ مُبَارَكٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/146",
            "text": "يُونُسَ بْنِ عَبْدِ اَلرَّحْمَنِ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/128",
            "text": "عَبْدِ اَللَّهِ بْنِ مُسْكَانَ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/14",
            "text": "أَبِي بَصِيرٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "سَمَاعَةَ بْنِ مِهْرَانَ قَالاَ: سَأَلْنَا أَبَا عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "plain",
            "text": "اَلرَّجُلِ يَكُونُ عَلَيْهِ صِيَامُ شَهْرَيْنِ مُتَتَابِعَيْنِ فَلَمْ يَقْدِرْ عَلَى اَلصِّيَامِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يَقْدِرْ عَلَى اَلْعِتْقِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يَقْدِرْ عَلَى اَلصَّدَقَةِ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:4:54:7",
      "text": [
        " «فَلْيَصُمْ ثَمَانِيَةَ عَشَرَ يَوْماً عَنْ كُلِّ عَشَرَةِ مَسَاكِينَ ثَلاَثَةَ أَيَّامٍ »."
      ]
    }
