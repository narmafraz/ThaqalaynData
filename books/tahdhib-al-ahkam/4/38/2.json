          {
            "kind": "narrator",
            "path": "/people/narrators/39",
            "text": "أَحْمَدَ بْنِ مُحَمَّدِ بْنِ أَبِي نَصْرٍ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/126",
            "text": "اِبْنِ أَبِي يَعْفُورٍ"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبِي عَبْدِ اَللَّهِ عَلَيْهِ اَلسَّلاَمُ : «أَنَّ أَرْضَ اَلْجِزْيَةِ لاَ تُرْفَعُ عَنْهُمُ اَلْجِزْيَةُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنَّمَا اَلْجِزْيَةُ عَطَاءُ اَلْمُهَاجِرِينَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلصَّدَقَةُ لِأَهْلِهَا اَلَّذِينَ سَمَّاهُمُ اَللَّهُ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/tahdhib-al-ahkam:4:38:2",
      "text": [
        " كِتَابِهِ وَ لَيْسَ لَهُمْ مِنَ اَلْجِزْيَةِ شَيْ ءٌ » ثُمَّ قَالَ «مَا أَوْسَعَ اَلْعَدْلَ » ثُمَّ قَالَ «إِنَّ اَلنَّاسَ يَسْتَغْنُونَ إِذَا عُدِلَ بَيْنَهُمْ وَ تُنْزِلُ اَلسَّمَاءُ رِزْقَهَا وَ تُخْرِجُ اَلْأَرْضُ بَرَكَتَهَا بِإِذْنِ اَللَّهِ عَزَّ وَ جَلَّ »."
      ]
    }
