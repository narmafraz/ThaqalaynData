    "verse": {
      "index": 341,
      "local_index": 46,
      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "46 - "
          },
          {
            "kind": "plain",
            "text": "حَدَّثَنا أَبي رَضِىَ اللهُ عَنْهُ قالَ: حَدَّثَنا سَعْدُ بْنُ عَبْدِ اللَّه قالَ: حَدَّثَنا مُحَمَّدِ بْنِ الحُسَيْنِ بْنِ أَبي الخَطَّاب،"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "إِبْراهيمِ بْنِ أَبي مَحْمُودٍ،"
          },
          {
            "kind": "plain",
            "text": " عَنْ "
          },
          {
            "kind": "plain",
            "text": "أَبي الحَسَن الرِّضا عَلَيْهِ السَّلامُ قالَ: سَأَلْتُهُ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "plain",
            "text": "الْقَيْ‏ءِ وَالرُّعَافِ وَالْمِدَّةِ وَالدَّمِ أَيَنْقُضُ الْوُضُوءَ"
          },
          {
            "kind": "plain",
            "text": " قَالَ"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/uyun-akhbar-al-rida:1:2:30:46",
      "source_url": "https://thaqalayn.net/hadith/11/2/30/46",
      "text": [
        " لا لا يَنْقُضُ شَيْئاً."
      ],
      "translations": {
        "en.dr-ali-peiravi": [
          "30-46 (The author of the book narrated) my father - may God be pleased with him - narrated that Sa’d ibn Abdullah quoted on the authority of Muhammad ibn Al-Hussein Abil Khattab, on the authority of Ibrahim ibn Abi Mahmood that Abil Hassan Al-Ridha (s) was asked, “Do vomiting, nosebleeds, pus and blood void the ablutions?” The Imam (s) replied, “No. Neither one of these will void the ablutions.”"
        ]
      }
    },
    "verse_translations": [
      "en.dr-ali-peiravi"
    ]
  },
