      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.2633 - Amir ibn Jutha'ah asked Imam (as) about dyed garments worn by a woman in Ihram.\nImam (as) said: \"There is no harm in it, except for prominently dyed garments (al-mufdam al-mashhoor).\""
        ]
      }
