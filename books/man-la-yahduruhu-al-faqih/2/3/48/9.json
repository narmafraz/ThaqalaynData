      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.2553 - Al-Halabi narrated from Abu ‘Abdillah (as) that he said:\nIbn Abbas said: \"Umrah has entered into Hajj until the Day of Resurrection.\""
