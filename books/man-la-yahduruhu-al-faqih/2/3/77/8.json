        " اَلطَّوَافِ فَقَالَ «كُلٌّ وَاسِعٌ مَا لَمْ يُؤْذِ أَحَداً »."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.2842 - Sa'id al-A'raj asked Imam (as) about those who are fast and those who are slow in circumambulation.\nImam (as) replied: \"Both are permissible as long as no one is harmed.\""
        ]
