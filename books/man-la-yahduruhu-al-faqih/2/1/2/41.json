      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.1638 - Al-Qasim ibn Sulayman narrated from Abu Abdullah Imam Jafar ibn Muhammad Al-Sadiq (as) who said:\n\"The charities of the Messenger of Allah (swt), peace and blessings be upon him and his family, and the charities of Imam Ali ibn Abi Talib (as) are permissible for Banu Hashim.\""
        ]
      }
