      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.1653 - Abu Ubaydah al-Haddha’ narrated from Abu Ja’far Imam Muhammad ibn Ali Al-Baqir (as) who said:\n\"Any non-Muslim under the protection of Islam (dhimmi) who buys land from a Muslim is obligated to pay Khums on it.\""
        ]
