      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.4750 - Imam Jafar ibn Muhammad Al-Sadiq (as) was asked: \"Why did Allah (swt) make His Prophet Muhammad (peace and blessings be upon him and his family) an orphan?\"\nImam (as) replied: \"So that no one would have authority over him.\""
        ]
