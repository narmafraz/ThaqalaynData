            },
            {
              "kind": "plain",
              "text": "أَوْلاَدِ عَلِيٍّ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "جَعْفَرٍ عَلَيْهِ اَلسَّلاَمُ"
            },
            {
              "kind": "plain",
              "text": " فَقَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/man-la-yahduruhu-al-faqih:3:3:15:4",
        "source_url": "https://thaqalayn.net/hadith/34/3/15/4",
        "text": [
          " \"بَنَاتُنَا لِبَنِينَا وَ بَنُونَا لِبَنَاتِنَا \"."
        ],
        "translations": {
          "en.bab-ul-qaim-publications": [
            "Hadith.4384 - The Prophet (peace be upon him and his family) looked at the children of Imam Ali ibn Abi Talib (as) and Ja'far (as), peace be upon them, and said:\n\"Our daughters are for our sons, and our sons are for our daughters.\""
          ]
        }
      },
      {
        "index": 2868,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
