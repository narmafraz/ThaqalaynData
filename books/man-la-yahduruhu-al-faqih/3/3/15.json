            },
            {
              "kind": "narrator",
              "path": "/people/narrators/213",
              "text": "و"
            },
            {
              "kind": "plain",
              "text": "َ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/man-la-yahduruhu-al-faqih:3:3:15:5",
        "source_url": "https://thaqalayn.net/hadith/34/3/15/5",
        "text": [
          " اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ : \" اَلْمُؤْمِنُونَ بَعْضُهُمْ أَكْفَاءُ بَعْضٍ \"."
        ],
        "translations": {
          "en.bab-ul-qaim-publications": [
            "Hadith.4385 - Imam Jafar ibn Muhammad Al-Sadiq (as) said: \"\nBelievers are equals to one another.\""
          ]
        }
      },
      {
        "index": 2869,
        "local_index": 6,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "4386 - "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/213",
              "text": "و"
            },
            {
              "kind": "plain",
              "text": "َ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/man-la-yahduruhu-al-faqih:3:3:15:6",
        "source_url": "https://thaqalayn.net/hadith/34/3/15/6",
        "text": [
          " عَلَيْهِ اَلسَّلاَمُ: \"اَلْكُفْؤُ أَنْ يَكُونَ عَفِيفاً وَ عِنْدَهُ يَسَارٌ\"."
        ],
        "translations": {
          "en.bab-ul-qaim-publications": [
            "Hadith.4386 - Imam (as) said: \"A suitable match is one who is chaste and possesses financial means.\""
          ]
        }
      }
    ]
  },
