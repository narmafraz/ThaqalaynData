      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.3321 - Hammad narrated from al-Halabi, from Abu Abdullah (as), that:\n\"The Messenger of Allah (swt), peace be upon him and his family, permitted the testimony of women along with the oath of the claimant in matters of debt, where he swears by Allah (swt) that his claim is true.\""
        ]
      }
