      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.3419 - It has been narrated:\n\"The protected area (harim) of a mosque is forty cubits from every side, and the protected area (harim) of a believer in the summer is a span.\"\nAnd it has also been narrated: \"The length of a cubit.\""
        ]
      }
