      "text": [
        " \"لاَ\"."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.3448 - Ya'qub ibn Shu'ayb asked him about a man who freed his bondwoman on the condition that she serves him for five years. However, she ran away, and then the man died.\nYa'qub asked: \"If his heirs find her, do they have the right to make her serve them?\"\nImam (as) said: \"No.\""
        ]
      }
    },
