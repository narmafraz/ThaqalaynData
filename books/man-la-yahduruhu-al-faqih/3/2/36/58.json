      "text": [
        " اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ : \"كُلُّ مَنْحُورٍ مَذْبُوحٍ حَرَامٌ وَ كُلُّ مَذْبُوحٍ مَنْحُورٍ حَرَامٌ\"."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.4177 - Imam Jafar ibn Muhammad Al-Sadiq (as) said:\n\"Every animal that should be slaughtered but is instead killed by stabbing is unlawful, and every animal that should be killed by stabbing but is instead slaughtered is unlawful.\""
        ]
      }
    },
