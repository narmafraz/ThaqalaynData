            "text": "3702 - "
          },
          {
            "kind": "plain",
            "text": "لِقَوْلِ اَلنَّبِيِّ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ : \"مَنْ حَلَفَ بِاللَّهِ فَلْيَصْدُقْ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَنْ حُلِفَ لَهُ بِاللَّهِ فَلْيَرْضَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَنْ لَمْ يَرْضَ فَلَيْسَ مِنَ اَللَّهِ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
