      "text": [
        " شَيْءٍ\"."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.3702 - The Prophet (peace be upon him and his family) said: \"Whoever swears by Allah (swt) should speak the truth, and whoever is sworn to by Allah (swt) should be satisfied. And whoever is not satisfied is not from Allah (swt) in any way.\""
        ]
      }
    },
