      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.912 - Imam (as) said:\n\"Whoever does not eat meat for forty days, their temperament may deteriorate, and if their temperament becomes poor, then recite the adhan (call to prayer) in their ear.\""
        ]
