      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.161 - Imam Jafar ibn Muhammad Al-Sadiq (as) was asked about a woman who has only one shirt and a child who urinates on her. What should She do?\nImam (as) said: 'She should wash the shirt once a day.'."
        ]
