      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.269 - The Messenger of Allah (sw) said:\n\"Whoever applies depilatory substances (to remove body hair) and dyes with henna, Allah (swt), the Most High, protects him from three things: leprosy, vitiligo (a skin disorder), and ‘al-ākilah’ (a type of skin disease or severe wound infection) until the next time he applies it.\""
        ]
      }
    },
