      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.28 - Ishaq ibn Ammar reported from Imam Jafar ibn Muhammad Al-Sadiq (as) that Imam Muhammad ibn Ali Al-Baqir (as) used to say:\n\"There is no harm in using the leftover water from which a mouse has drunk, for drinking or performing ablution.\""
        ]
