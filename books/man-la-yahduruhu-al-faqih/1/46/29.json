      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.943 - It is reported from Safwan al-Jammal that He said:\n“I prayed behind Imam Jafar ibn Muhammad Al-Sadiq (as) for several days, and he would make the Qunoot in every prayer, whether he recited aloud or not”."
        ]
