      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.1207 - Abu Basir narrated from Imam Jafar ibn Muhammad Al-Sadiq (as) that when he asked: \"Does the Imam guarantee (the correctness of) the prayer?\"\nImam (as) replied: \"No, he is not a guarantor.\""
        ]
