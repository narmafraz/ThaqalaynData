      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "663 - "
          },
          {
            "kind": "plain",
            "text": "وَقَالَ اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ: «إِذَا غَابَتِ اَلشَّمْسُ فَقَدْ حَلَّ اَلْإِفْطَارُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "وَجَبَتِ اَلصَّلاَةُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِذَا صَلَّيْتَ اَلْمَغْرِبَ فَقَدْ دَخَلَ وَقْتُ اَلْعِشَاءِ اَلْآخِرَةِ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "اِن"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/man-la-yahduruhu-al-faqih:1:33:18",
      "source_url": "https://thaqalayn.net/hadith/34/1/33/663",
      "text": [
        "ْتِصَافِ اَللَّيْلِ."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.663 - Imam Jafar ibn Muhammad Al-Sadiq (as) said:\n\"When the sun sets, it becomes permissible to break the fast (if one is fasting) and the Maghrib prayer becomes obligatory. Once you have performed the Maghrib prayer, the time for the Isha (night) prayer begins and extends until midnight.\""
        ]
      }
    },
