          {
            "kind": "plain",
            "text": "وَقَالَ رَسُولُ اَللَّهِ صَلَّى اَللَّهُ عَلَيْهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "آلِهِ: «مَثَلُ اَلصَّلاَةِ مَثَلُ عَمُودِ اَلْفُسْطَاطِ إِذَا ثَبَتَ اَلْعَمُودُ ثَبَتَتِ اَلْأَطْنَابُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْأَوْتَادُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْغِشَاءُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِذَا اِن"
