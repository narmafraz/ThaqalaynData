      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.98 - Imam Musa ibn Jafar Al-Kadhim (as) was asked about a man whose leather socks (khuffs) are torn, and he puts his hand in and wipes over the tops of his feet. Is this sufficient?\nImam (as) said: \"Yes.\""
        ]
      }
