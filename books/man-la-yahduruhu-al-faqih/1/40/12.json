      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.760 - Ali ibn Ja'far asked his brother Imam Musa ibn Jafar Al-Kadhim (as) about whether it is permissible for a man to pray while there is a rack with clothes hanging on it in front of him.\nImam (as) said: \"There is no harm.\""
        ]
      }
