      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.762 - He (Ali ibn Ja'far) asked him (Imam Musa ibn Jafar Al-Kadhim (as)) about whether it is permissible for a man to pray on growing vegetation (fresh grass).\nImam (as) said: \"If he places his forehead on the ground, then there is no harm.\""
        ]
