          {
            "kind": "plain",
            "text": "وَقَالَ اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ: «اَلْجَمَّالُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "اَلْمُكَارِي إِذَا جَدَّ بِهِمَا اَلسَّيْرُ قَصَّرَا"
          },
          {
            "kind": "plain",
            "text": " فِي"
