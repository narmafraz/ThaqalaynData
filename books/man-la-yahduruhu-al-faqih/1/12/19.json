            "text": "وَقَالَ اَلصَّادِقُ عَلَيْهِ اَلسَّلاَمُ: «فِي اَلسِّوَاكِ اِثْنَتَا عَشْرَةَ خَصْلَةً هُوَ مِنَ اَلسُّنَّةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَطْهَرَةٌ لِلْفَمِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَجْلاَةٌ لِلْبَصَرِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُرْضِي اَلرَّحْمَنَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُبَيِّضُ اَلْأَسْنَانَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَذْهَبُ بِالْحَفْرِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يَشُدُّ اَللِّثَةَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "يُشَهِّي اَلطَّعَامَ"
          },
