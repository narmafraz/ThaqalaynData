        " رَجُلٍ سَرَقَ مِنْ بُسْتَانٍ عِذْقاً قِيمَتُهُ دِرْهَمَانِ قَالَ \"يُقْطَعُ بِهِ\"."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "Hadith.5128 - Ishaq ibn Ammar narrated from Abu Abdullah (as) regarding a man who stole a cluster of dates from an orchard worth two dirhams.\nImam (as) said: \"His hand is to be cut off for that.\""
        ]
