      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "إِذَا تَرَكَ الرَّجُلُ ابْناً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يَتْرُكْ زَوْجَةً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَا أَبَوَيْنِ فَالْمَالُ كُلُّهُ لِلِابْنِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "كَذَلِكَ إِنْ كَانَا اثْنَيْنِ أَوْ أَكْثَرَ مِنْ ذَلِكَ فَالْمَالُ بَيْنَهُمْ بِالسَّوِيَّةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "كَذَلِكَ إِنْ تَرَكَ ابْنَةً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يَتْرُكْ زَوْجاً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَا أَبَوَيْنِ فَالْمَالُ كُلُّهُ لِلِابْنَةِ لِأَنَّ اللَّهَ عَزَّ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "جَلَّ جَعَلَ الْمَالَ لِلْوَلَدِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يُسَمِّ لِلِابْنَةِ النِّصْفَ إِلَّا مَعَ الْأَبَوَيْنِ‌"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "كَذَلِكَ إِنْ كَانَتَا اثْنَتَيْنِ أَوْ أَكْثَرَ فَالْمَالُ كُلُّهُ لَهُنَّ بِالسَّوِيَّةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِنْ تَرَكَ ابْنَةً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "ابْنَةَ ابْنٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "ابْنَ ابْنٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَمْ يَكُنْ زَوْجٌ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَا أَبَوَانِ فَالْمَالُ كُلُّهُ لِلِابْنَةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَيْسَ لِوَلَدِ الْوَلَدِ مَعَ وَلَدِ الصُّلْبِ شَيْ‌ءٌ لِأَنَّ مَنْ تَقَرَّبَ بِنَفْسِهِ كَانَ أَوْلَى"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أَحَقَّ بِالْمَالِ مِمَّنْ تَقَرَّبَ بِغَيْرِهِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَنْ كَانَ أَقْرَبَ"
          },
          {
            "kind": "plain",
            "text": " إِلَى "
          },
          {
            "kind": "plain",
            "text": "الْمَيِّتِ‌ بِبَطْنٍ كَانَ أَحَقَّ بِالْمَالِ مِمَّنْ كَانَ أَبْعَدَ بِبَطْنٍ فَإِنْ تَرَكَ ابْناً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "ابْنَةً أَوْ بَنِينَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "بَنَاتٍ فَالْمَالُ كُلُّهُ لَهُمْ‌ لِلذَّكَرِ مِثْلُ حَظِّ الْأُنْثَيَيْنِ‌ إِذَا لَمْ يَكُنْ مَعَهُمْ زَوْجٌ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَا وَالِدَانِ‌ فَإِنْ تَرَكَ ابْنَةً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أَخاً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "أُخْتاً"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "جَدّاً فَالْمَالُ كُلُّهُ لِلِابْنَةِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "لَا يَرِثُ مَعَ الِابْنَةِ أَحَدٌ إِلَّا الِابْنُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "الزَّوْجُ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "الْوَالِدَانِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "كَذَلِكَ لَا يَرِثُ مَعَ‌ الْوَلَدِ الذَّكَرِ أَحَدٌ إِلَّا الزَّوْجُ‌"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "الْأَبَوَانِ عَلَى مَا ذَكَرَهُ اللَّهُ عَزَّ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "جَلَّ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/man-la-yahduruhu-al-faqih:4:131:1",
      "source_url": "https://thaqalayn.net/hadith/34/1/130/0",
      "text": [
        " كِتَابِهِ."
      ],
      "translations": {
        "en.bab-ul-qaim-publications": [
          "If a man leaves behind a son and does not leave a wife or parents, then the entire estate belongs to the son. Similarly, if there are two or more sons, the estate is divided equally among them.\nIf he leaves a daughter and no husband or parents, then the entire estate belongs to the daughter because Allah (swt), the Almighty and Majestic, has allocated the estate to the offspring and specified half of the share for a daughter only in the presence of parents. Likewise, if there are two or more daughters, the estate is divided equally among them.\nIf he leaves a daughter, a granddaughter (daughter's daughter), and a grandson (daughter's son), and there is no husband or parents, the entire estate belongs to the daughter. The grandchildren do not inherit alongside the direct offspring because those who are closer in lineage take precedence over those further away. The closer relation to the deceased is more entitled to the estate than those who are further removed.\nIf he leaves both a son and a daughter, or multiple sons and daughters, the entire estate is divided among them with the male receiving twice the share of the female, provided there is no spouse or parents.\nIf he leaves a daughter, a brother, a sister, and a grandfather, the entire estate belongs to the daughter. No one inherits alongside a daughter except a son, a husband, or the parents.\nSimilarly, no one inherits alongside a male offspring except the spouse and the parents, according to what Allah (swt), the Almighty, has mentioned in His (swt) Book."
        ]
      }
    },
    "verse_translations": [
