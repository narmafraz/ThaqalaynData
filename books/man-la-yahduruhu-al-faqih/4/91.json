        "text": [
          " : \"إِذَا بَلَغَ اَلْغُلاَمُ عَشْرَ سِنِينَ جَازَتْ وَصِيَّتُهُ\"."
        ],
        "translations": {
          "en.bab-ul-qaim-publications": [
            "Hadith.5450 - Muhammad ibn Abi Umayr narrated from Aban ibn Uthman from Abd Al-Rahman ibn Abi Abdullah from Abu Abdullah Imam Jafar ibn Muhammad Al-Sadiq (as), who said:\n\"When a boy reaches the age of ten, his will becomes valid.\""
          ]
        }
