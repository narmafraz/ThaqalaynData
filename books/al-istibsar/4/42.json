    "verses": [
      {
        "index": 4045,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينُ بنُ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ عَن زُرعَةَ عَن سَمَاعَةَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:42:1",
        "text": [
          " سَأَلتُهُ عَنِ الرّجُلِ يفَترَيِ عَلَي الرّجُلِ ثُمّ يَعفُو عَنهُ ثُمّ يُرِيدُ أَن يَجلِدَهُ بَعدَ التّوبَةِ قَالَ لَيسَ لَهُ ذَلِكَ بَعدَ العَفوِ"
        ]
      },
      {
        "index": 4046,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "الحَسَنُ بنُ مَحبُوبٍ عَن أَبِي أَيّوبَ عَن سَمَاعَةَ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:42:2",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن رَجُلٍ يَقذِفُ الرّجُلَ بِالزّنَي فَيَعفُو عَنهُ وَ يَجعَلُهُ مِن ذَلِكَ فِي حِلّ ثُمّ إِنّهُ بَعدُ يَبدُو لَهُ فِي أَن يُقَدّمَهُ حَتّي يُحَدّ لَهُ قَالَ لَيسَ لَهُ حَدّ بَعدَ العَفوِ"
        ]
      },
      {
        "index": 4047,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ يُونُسُ بنُ عَبدِ الرّحمَنِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "العَلَاءِ عَن مُحَمّدِ بنِ مُسلِمٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:42:3",
        "text": [
          " سَأَلتُهُ عَنِ الرّجُلِ يَقذِفُ امرَأَتَهُ قَالَ يُجلَدُ قُلتُ أَ رَأَيتَ إِن عَفَت عَنهُ قَالَ لَا وَ لَا كَرَامَةَ فَالوَجهُ فِي هَذَا الخَبَرِ أَن نَحمِلَهُ عَلَي أَنّهَا إِذَا رَفَعَتهُ إِلَي الإِمَامِ أَوِ الحَاكِمِ لَم يَكُن لَهَا بَعدَ ذَلِكَ عَفوٌ وَ قَد أَورَدنَا تَفصِيلَ ذَلِكَ فِي كِتَابِنَا الكَبِيرِ وَ ألّذِي يَدُلّ عَلَي ذَلِكَ"
        ]
      },
      {
        "index": 4048,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ سَهلُ بنُ زِيَادٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ مَحبُوبٍ عَن ضُرَيسٍ الكنُاَسيِ ّ عَن أَبِي جَعفَرٍ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:42:4",
        "text": [
          " لَا يُعفَي عَنِ الحُدُودِ التّيِ لِلّهِ دُونَ الإِمَامِ فَأَمّا مَا كَانَ مِن حَقّ النّاسِ فَلَا بَأسَ أَن يُعفَي عَنهُ دُونَ الإِمَامِ"
        ]
      },
      {
        "index": 4049,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/5",
              "text": "أَحمَدُ بنُ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/10",
              "text": "ابنِ مَحبُوبٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "العَلَاءِ عَن مُحَمّدِ بنِ مُسلِمٍ عَن أَبِي جَعفَرٍ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:42:5",
        "text": [
          " قُلتُ لَهُ رَجُلٌ جَنَي إلِيَ ّ أَعفُو عَنهُ أَو أَرفَعُهُ إِلَي السّلطَانِ قَالَ هُوَ حَقّكَ إِن عَفَوتَ عَنهُ فَحَسَنٌ وَ إِن رَفَعتَهُ إِلَي الإِمَامِ فَإِنّمَا طَلَبتَ حَقّكَ وَ كَيفَ لَكَ بِالإِمَامِ"
        ]
      }
    ]
