        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينُ بنُ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن حَمّادٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/28",
              "text": "الحلَبَيِ ّ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:1",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن صَيدِ الحِيتَانِ وَ إِن لَم يُسَمّ فَقَالَ لَا بَأسَ وَ سَأَلتُهُ عَن صَيدِ المَجُوسِ السّمَكَ آكُلُهُ فَقَالَ مَا كُنتُ لآِكُلَهُ حَتّي أَنظُرَ إِلَيهِ"
        ]
      },
      {
        "index": 3768,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن حَمّادٍ عَن حَرِيزٍ عَن مُحَمّدِ بنِ مُسلِمٍ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:2",
        "text": [
          "سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن مجَوُسيِ ّ يَصِيدُ السّمَكَ أَ يُؤكَلُ مِنهُ فَقَالَ مَا كُنتُ لآِكُلَهُ حَتّي أَنظُرَ إِلَيهِ قَالَ حَمّادٌ يعَنيِ حَتّي أَسمَعَهُ يسُمَيّ قَالَ مُحَمّدُ بنُ الحَسَنِ ألّذِي ذَكَرَهُ حَمّادٌ فِي تَأوِيلِ الخَبَرِ غَيرُ صَحِيحٍ لِأَنّا قَد بَيّنّا فِي الرّوَايَةِ الأُولَي أَنّهُ لَا يُرَاعَي فِي صَيدِ السّمَكِ التّسمِيَةُ وَ يَزِيدُ ذَلِكَ بَيَاناً"
        ]
      },
      {
        "index": 3769,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ عَلِيّ عَن أَبِيهِ عَن عَمرِو بنِ عُثمَانَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "المُفَضّلِ بنِ صَالِحٍ عَن زَيدٍ الشّحّامِ عَن أَبِي عَبدِ اللّهِ ع أَنّهُ سُئِلَ عَن صَيدِ الحِيتَانِ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "إِن لَم يُسَمّ عَلَيهِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:3",
        "text": [
          " لَا بَأسَ بِهِ إِن كَانَ حَيّاً أَن تَأخُذَهُ"
        ]
      },
      {
        "index": 3770,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن فَضَالَةَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "العَلَاءِ عَن مُحَمّدِ بنِ مُسلِمٍ عَن أَحَدِهِمَا ع مِثلَ ذَلِكَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:4",
        "text": [
          " وَ سَأَلتُهُ عَن صَيدِ السّمَكِ وَ لَا يُسَمّي قَالَ لَا بَأسَ"
        ]
      },
      {
        "index": 3771,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ مُحَمّدُ بنُ يَعقُوبَ عَن عَلِيّ بنِ اِبرَاهِيمَ عَن أَبِيهِ عَن مُحَمّدِ بنِ أَبِي عُمَيرٍ عَن حَمّادٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحلَبَيِ ّ عَن أَبِي عَبدِ اللّهِ ع أَنّهُ سُئِلَ عَن صَيدِ المَجُوسِ حِينَ يَضرِبُونَ بِالشّبَاكِ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "يُسَمّونَ بِالشّركِ"
            },
            {
              "kind": "plain",
              "text": " فَقَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:5",
        "text": [
          " لَا بَأسَ بِصَيدِهِم إِنّمَا صَيدُ الحِيتَانِ أَخذُهَا"
        ]
      },
      {
        "index": 3772,
        "local_index": 6,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحُسَينِ بنِ مُحَمّدٍ عَن مُعَلّي بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الوَشّاءِ عَن عَبدِ اللّهِ بنِ سِنَانٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:6",
        "text": [
          " سَمِعتُ أَبَا عَبدِ اللّهِ ع قَالَ لَا بَأسَ بِالسّمَكِ ألّذِي يَصِيدُهُ المجَوُسيِ ّ"
        ]
      },
      {
        "index": 3773,
        "local_index": 7,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "الحُسَينُ بنُ سَعِيدٍ عَن عُثمَانَ عَن سَمَاعَةَ عَن أَبِي بَصِيرٍ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:7",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن صَيدِ المَجُوسِ السّمَكَ حِينَ يَضرِبُونَ بِالشّبَكِ وَ لَا يُسَمّونَ أَو يهَوُديِ ّ وَ لَا يسُمَيّ قَالَ لَا بَأسَ إِنّمَا صَيدُ الحِيتَانِ أَخذُهَا"
        ]
      },
      {
        "index": 3774,
        "local_index": 8,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "النّضرِ عَن هِشَامِ بنِ سَالِمٍ عَن سُلَيمَانَ بنِ خَالِدٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:8",
        "text": [
          "سَأَلتُ أَبَا عَبدِ اللّهِ ع عَنِ الحِيتَانِ التّيِ يَصِيدُهَا المَجُوسُ فَقَالَ إِنّ عَلِيّاً ع كَانَ يَقُولُ الحِيتَانُ وَ الجَرَادُ ذكَيِ ّ"
        ]
      },
      {
        "index": 3775,
        "local_index": 9,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ فَضّالٍ عَن يُونُسَ بنِ يَعقُوبَ عَن أَبِي مَريَمَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:9",
        "text": [
          " قُلتُ لأِبَيِ عَبدِ اللّهِ ع مَا تَقُولُ فِيمَا صَادَتِ المَجُوسُ مِنَ الحِيتَانِ فَقَالَ كَانَ عَلِيّ ع يَقُولُ الحِيتَانُ وَ الجَرَادُ ذكَيِ ّ"
        ]
      },
      {
        "index": 3776,
        "local_index": 10,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ عَلِيّ الوَشّاءِ عَن عَبدِ اللّهِ بنِ سِنَانٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:10",
        "text": [
          " سَمِعتُ أَبَا عَبدِ اللّهِ ع يَقُولُ لَا بَأسَ بِكَوَامِيخِ المَجُوسِ وَ لَا بَأسَ بِصَيدِهِمُ السّمَكَ فَالوَجهُ فِي هَذِهِ الأَخبَارِ أَن نَحمِلَهَا عَلَي أَنّهُ لَا بَأسَ بِصَيدِ المَجُوسِ إِذَا أَخَذَهُ الإِنسَانُ مِنهُم حَيّاً قَبلَ أَن يَمُوتَ فَلَا يُقبَلُ قَولُهُم فِي إِخرَاجِ السّمَكِ مِنَ المَاءِ حَيّاً لِأَنّهُم لَا يُؤمَنُونَ عَلَي ذَلِكَ يَدُلّ عَلَي ذَلِكَ"
        ]
      },
      {
        "index": 3777,
        "local_index": 11,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ الحُسَينُ بنُ سَعِيدٍ عَن فَضَالَةَ عَن أَبَانٍ عَن عِيسَي بنِ عَبدِ اللّهِ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:4:21:11",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن صَيدِ المَجُوسِ فَقَالَ لَا بَأسَ إِذَا أَعطَوكَهُ حَيّاً وَ السّمَكَ أَيضاً وَ إِلّا فَلَا تُجِز شَهَادَتَهُم إِلّا أَن تَشهَدَهُ أَنتَ"
        ]
      }
    ]
  },
