    "titles": {
      "ar": "294- بَابُ أَنّهُ لَا قِرَاءَةَ فِي الصّلَاةِ عَلَي المَيّتِ"
    },
    "verse_count": 3,
    "verse_start_index": 1762,
    "verses": [
      {
        "index": 1763,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُحَمّدُ بنُ يَعقُوبَ عَن عَلِيّ بنِ اِبرَاهِيمَ عَن أَبِيهِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن عُمَرَ بنِ أُذَينَةَ عَن مُحَمّدِ بنِ مُسلِمٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/18",
              "text": "زُرَارَةَ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/557",
              "text": "مَعمَرِ بنِ يَحيَي"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "إِسمَاعِيلَ الجعُفيِ ّ عَن أَبِي جَعفَرٍ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:272:1",
        "text": [
          " لَيسَ فِي الصّلَاةِ عَلَي المَيّتِ قِرَاءَةٌ وَ لَا دُعَاءٌ مُوَقّتٌ تَدعُو بِمَا بَدَا لَكَ وَ أَحَقّ المَوتَي أَن يُدعَي لَهُ المُؤمِنُ وَ أَن يُبدَأَ بِالصّلَاةِ عَلَي رَسُولِ اللّهِ\u001eص"
        ]
      },
      {
        "index": 1764,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدِ بنِ عِيسَي عَن مُحَمّدِ بنِ إِسمَاعِيلَ بنِ بَزِيعٍ عَن عَمّهِ حَمزَةَ بنِ بَزِيعٍ عَن عَلِيّ بنِ سُوَيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الرّضَا ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:272:2",
        "text": [
          "مَا يُعلَمُ قَالَ فِي الصّلَاةِ عَلَي الجَنَائِزِ قَالَ تَقرَأُ فِي الأُولَي بِأُمّ الكِتَابِ وَ فِي الثّانِيَةِ تصُلَيّ عَلَي النّبِيّ وَ آلِهِ وَ تَدعُو فِي الثّالِثَةِ لِلمُؤمِنِينَ وَ المُؤمِنَاتِ وَ تَدعُو فِي الرّابِعَةِ لِمَيّتِكَ وَ الخَامِسَةُ تَنصَرِفُ بِهَا"
        ]
      },
      {
        "index": 1765,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "وَ "
            },
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي عَن جَعفَرِ بنِ مُحَمّدِ بنِ عَبدِ اللّهِ القمُيّ ّ عَن عَبدِ اللّهِ بنِ مَيمُونٍ القَدّاحِ عَن جَعفَرٍ عَن أَبِيهِ أَنّ عَلِيّاً ع كَانَ إِذَا صَلّي عَلَي مَيّتٍ يَقرَأُ بِفَاتِحَةِ الكِتَابِ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "يصُلَيّ عَلَي النّبِيّ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "آلِهِ تَمَامَ الحَدِيثِ فَالوَجهُ"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:272:3",
        "text": [
          " هَذَينِ الخَبَرَينِ التّقِيّةُ لِأَنّهُمَا مُوَافِقَانِ لِمَذَاهِبِ بَعضِ العَامّةِ"
        ]
      }
    ]
  },
