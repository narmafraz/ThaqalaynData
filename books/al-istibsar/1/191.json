    "path": "/books/al-istibsar:1:191",
    "titles": {
      "ar": "213- بَابُ السّهوِ فِي الرّكعَتَينِ الأَوّلَتَينِ"
    },
    "verse_count": 13,
    "verse_start_index": 1298,
    "verses": [
      {
        "index": 1299,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينُ بنُ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "النّضرِ عَن عَاصِمٍ عَن مُحَمّدِ بنِ مُسلِمٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:1",
        "text": [
          " سَأَلتُ أَبَا جَعفَرٍ ع عَن رَجُلٍ شَكّ فِي الرّكعَةِ الأُولَي قَالَ يَستَأنِفُ"
        ]
      },
      {
        "index": 1300,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن مُحَمّدِ بنِ سِنَانٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ مُسكَانَ عَن عَنبَسَةَ بنِ مُصعَبٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:2",
        "text": [
          " قَالَ لِي أَبُو عَبدِ اللّهِ ع إِذَا شَكَكتَ فِي الرّكعَتَينِ الأَوّلَتَينِ فَأَعِد"
        ]
      },
      {
        "index": 1301,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "القرَوَيِ ّ عَن أَبَانٍ عَن إِسمَاعِيلَ الجعُفيِ ّ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي يَعفُورٍ عَن أَبِي جَعفَرٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "أَبِي عَبدِ اللّهِ ع أَنّهُمَا"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:3",
        "text": [
          "ا إِذَا لَم تَدرِ أَ وَاحِدَةً صَلّيتَ أَم ثِنتَينِ فَاستَقبِل"
        ]
      },
      {
        "index": 1302,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "النّضرِ عَن مُوسَي بنِ بَكرٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:4",
        "text": [
          " سَأَلَهُ الفُضَيلُ عَنِ السّهوِ فَقَالَ إِذَا شَكَكتَ فِي الأَوّلَتَينِ فَأَعِد"
        ]
      },
      {
        "index": 1303,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ عَن زُرعَةَ عَن سَمَاعَةَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:5",
        "text": [
          " قَالَ إِذَا سَهَا الرّجُلُ فِي الرّكعَتَينِ الأَوّلَتَينِ مِنَ الظّهرِ وَ العَصرِ وَ العَتَمَةِ فَلَم يَدرِ وَاحِدَةً صَلّي أَم ثِنتَينِ فَعَلَيهِ أَن يُعِيدَ الصّلَاةَ"
        ]
      },
      {
        "index": 1304,
        "local_index": 6,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن فَضَالَةَ عَن رِفَاعَةَ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:6",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن رَجُلٍ لَا يدَريِ أَ رَكعَةً صَلّي أَمِ اثنَتَينِ فَقَالَ يُعِيدُ"
        ]
      },
      {
        "index": 1305,
        "local_index": 7,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن فَضَالَةَ عَن حُسَينِ بنِ عُثمَانَ عَن هَارُونَ بنِ خَارِجَةَ عَن أَبِي بَصِيرٍ عَن أَبِي عَبدِ اللّهِ ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:7",
        "text": [
          " إِذَا سَهَوتَ فِي الأَوّلَتَينِ فَأَعِدهُمَا حَتّي تُثبِتَهُمَا"
        ]
      },
      {
        "index": 1306,
        "local_index": 8,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن فَضَالَةَ عَن حَمّادٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/532",
              "text": "الفَضلِ بنِ عَبدِ المَلِكِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:8",
        "text": [
          " قَالَ لِي إِذَا لَم تَحفَظِ الرّكعَتَينِ الأَوّلَتَينِ فَأَعِد صَلَاتَكَ"
        ]
      },
      {
        "index": 1307,
        "local_index": 9,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَلِيّ بنُ اِبرَاهِيمَ عَن أَبِيهِ عَن حَمّادٍ عَن حَرِيزٍ عَن زُرَارَةَ عَن أَحَدِهِمَا ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:9",
        "text": [
          " قُلتُ لَهُ رَجُلٌ لَا يدَريِ أَ وَاحِدَةً صَلّي أَمِ اثنَتَينِ قَالَ يُعِيدُ"
        ]
      },
      {
        "index": 1308,
        "local_index": 10,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي عَن أَحمَدَ بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/89",
              "text": "الحَسَنِ بنِ عَلِيّ الوَشّاءِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:10",
        "text": [
          " قَالَ لِي أَبُو الحَسَنِ الرّضَا ع الإِعَادَةُ فِي الرّكعَتَينِ الأَوّلَتَينِ وَ السّهوُ فِي الرّكعَتَينِ الأَخِيرَتَينِ"
        ]
      },
      {
        "index": 1309,
        "local_index": 11,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدِ بنِ عِيسَي عَن عَلِيّ بنِ الحَكَمِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/216",
              "text": "الحُسَينِ بنِ أَبِي العَلَاءِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:11",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَنِ الرّجُلِ لَا يدَريِ أَ رَكعَتَينِ صَلّي أَم وَاحِدَةً قَالَ يُتِمّ"
        ]
      },
      {
        "index": 1310,
        "local_index": 12,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "وَ "
            },
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/1044",
              "text": "السنّديِ ّ بنِ الرّبِيعِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ مَحبُوبٍ عَن عَبدِ الرّحمَنِ بنِ الحَجّاجِ عَن أَبِي اِبرَاهِيمَ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:12",
        "text": [
          " فِي الرّجُلِ لَا يدَريِ رَكعَةً صَلّي أَم ثِنتَينِ قَالَ يبَنيِ عَلَي الرّكعَةِ"
        ]
      },
      {
        "index": 1311,
        "local_index": 13,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "وَ مَا رَوَاهُ سَعدُ بنُ عَبدِ اللّهِ عَن مُحَمّدِ بنِ الحُسَينِ عَن أَحمَدَ بنِ مُحَمّدِ بنِ أَبِي نَصرٍ عَن عَبدِ الكَرِيمِ بنِ عَمرٍو عَن عَبدِ اللّهِ بنِ أَبِي يَعفُورٍ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:191:13",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع فِي الرّجُلِ لَا يدَريِ أَ رَكعَتَينِ صَلّي أَم وَاحِدَةً قَالَ يُتِمّ بِرَكعَةٍ فَأَوّلُ مَا فِي هَذِهِ الأَخبَارِ أَنّهَا لَا تُعَارِضُ مَا قَدّمنَاهُ لِأَنّهَا أَضعَافُ هَذِهِ وَ لَا يَجُوزُ العُدُولُ عَنِ الأَكثَرِ إِلَي الأَقَلّ لِمَا قَد بَيّنّاهُ فِي غَيرِ مَوضِعٍ وَ لَو كَانَ مُعَارِضَةً لَهَا وَ مُسَاوِيَةً لَم يَكُن فِيهَا تَنَاقُضٌ لِأَنّهُ لَيسَ فِي شَيءٍ مِن هَذِهِ الأَخبَارِ أَنّ الشّكّ إِذَا وَقَعَ فِي الأَوّلَةِ وَ الثّانِيَةِ مِن صَلَاةِ الفَرَائِضِ أَوِ النّوَافِلِ وَ إِذَا لَم يَكُن هَذَا فِي الخَبَرِ حَمَلنَاهَا عَلَي النّوَافِلِ لِأَنّ النّوَافِلَ عِندَنَا لَا سَهوَ فِيهَا وَ يبَنيِ المصُلَيّ إِن شَاءَ عَلَي الأَقَلّ وَ إِن شَاءَ عَلَي الأَكثَرِ وَ البِنَاءُ عَلَي الأَقَلّ أَفضَلُ فَحَمَلنَا هَذِهِ الأَخبَارَ عَلَي مَا ذَكَرنَاهُ مِنَ النّوَافِلِ لِئَلّا يَتَنَاقَضَ الأَخبَارُ"
        ]
      }
    ]
  },
