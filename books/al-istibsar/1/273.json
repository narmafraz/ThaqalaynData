              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/28",
              "text": "الحلَبَيِ ّ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:273:1",
        "text": [
          " قَالَ أَبُو عَبدِ اللّهِ ع لَيسَ فِي الصّلَاةِ عَلَي المَيّتِ تَسلِيمٌ"
        ]
      },
      {
        "index": 1767,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن عَلِيّ عَن أَبِيهِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن حَمّادِ بنِ عُثمَانَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/28",
              "text": "الحلَبَيِ ّ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "زُرَارَةَ عَن أَبِي جَعفَرٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/669",
              "text": "أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:273:2",
        "text": [
          " لَيسَ فِي الصّلَاةِ عَلَي المَيّتِ تَسلِيمٌ"
        ]
      },
      {
        "index": 1768,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "أَحمَدُ بنُ مُحَمّدٍ عَن إِسمَاعِيلَ بنِ سَعدٍ الأشَعرَيِ ّ عَن أَبِي الحَسَنِ الرّضَا ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:273:3",
        "text": [
          " سَأَلتُهُ عَنِ الصّلَاةِ عَلَي المَيّتِ قَالَ أَمّا المُؤمِنُ فَخَمسُ تَكبِيرَاتٍ وَ أَمّا المُنَافِقُ فَأَربَعٌ وَ لَا سَلَامَ فِيهَا"
        ]
      },
      {
        "index": 1769,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ الحُسَينُ بنُ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ عَن زُرعَةَ عَن سَمَاعَةَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:273:4",
        "text": [
          " سَأَلتُهُ عَنِ الصّلَاةِ عَلَي المَيّتِ قَالَ خَمسُ تَكبِيرَاتٍ فَإِذَا فَرَغتَ مِنهَا سَلّمتَ عَن يَمِينِكَ فَالوَجهُ فِي هَذِهِ الرّوَايَةِ التّقِيّةُ لِأَنّهَا مُوَافِقَةٌ لِمَذَاهِبِ العَامّةِ"
