        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُحَمّدُ بنُ يَعقُوبَ عَن عِدّةٍ مِن أَصحَابِنَا عَن سَهلِ بنِ زِيَادٍ عَن مُحَمّدِ بنِ سِنَانٍ عَن عَبدِ اللّهِ بنِ مُسكَانَ"
