    "titles": {
      "ar": "183- بَابُ السّجُودِ عَلَي الجَبهَةِ"
    },
    "verse_count": 5,
    "verse_start_index": 1141,
    "verses": [
      {
        "index": 1142,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "أخَبرَنَيِ الشّيخُ رَحِمَهُ اللّهُ عَن أَحمَدَ بنِ مُحَمّدٍ عَن أَبِيهِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الصّفّارِ عَن أَحمَدَ بنِ مُحَمّدِ بنِ عِيسَي عَن أَبِي عَبدِ اللّهِ البرَقيِ ّ عَن مُحَمّدِ بنِ مُصَادِفٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:160:1",
        "text": [
          " سَمِعتُ أَبَا عَبدِ اللّهِ ع يَقُولُ إِنّمَا السّجُودُ عَلَي الجَبهَةِ وَ لَيسَ عَلَي الأَنفِ سُجُودٌ"
        ]
      },
      {
        "index": 1143,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُحَمّدُ بنُ عَلِيّ بنِ مَحبُوبٍ عَن مُوسَي بنِ عُمَيرٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/244",
              "text": "الحَسَنِ بنِ عَلِيّ بنِ فَضّالٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/56",
              "text": "ابنِ بُكَيرٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "ثَعلَبَةَ بنِ مَيمُونٍ عَن بُرَيدٍ عَن أَبِي جَعفَرٍ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:160:2",
        "text": [
          "الجَبهَةُ إِلَي الأَنفِ أَيّ ذَلِكَ أَصَبتَ بِهِ الأَرضَ فِي السّجُودِ أَجزَأَكَ وَ السّجُودُ عَلَيهِ كُلّهِ أَفضَلُ"
        ]
      },
      {
        "index": 1144,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/5",
              "text": "أَحمَدُ بنُ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ عَلِيّ بنِ فَضّالٍ عَن مَروَانَ بنِ مُسلِمٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/233",
              "text": "عَمّارٍ الساّباَطيِ ّ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:160:3",
        "text": [
          " مَا بَينَ قُصَاصِ الشّعرِ إِلَي طَرَفِ الأَنفِ مَسجَدٌ أَيّ ذَلِكَ أَصَبتَ بِهِ الأَرضَ أَجزَأَكَ"
        ]
      },
      {
        "index": 1145,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدٍ عَن مُحَمّدِ بنِ يَحيَي عَن عَمّارٍ عَن جَعفَرٍ عَن أَبِيهِ ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:160:4",
        "text": [
          " قَالَ عَلِيّ ع لَا تجُزيِ صَلَاةٌ لَا يُصِيبُ الأَنفُ مَا يُصِيبُ الجَبِينُ فَهَذِهِ الرّوَايَةُ مَحمُولَةٌ عَلَي ضَربٍ مِنَ الكَرَاهِيَةِ دُونَ الفَرضِ لِأَنّ الفَرضَ هُوَ السّجُودُ عَلَي الجَبهَةِ وَ الإِرغَامَ بِالأَنفِ سُنّةٌ عَلَي مَا بَيّنّاهُ وَ يُؤَكّدُ مَا قُلنَاهُ"
        ]
      },
      {
        "index": 1146,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ مُحَمّدُ بنُ عَلِيّ بنِ مَحبُوبٍ عَن أَحمَدَ بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي نَجرَانَ عَن حَمّادِ بنِ عِيسَي عَن حَرِيزٍ عَن زُرَارَةَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:160:5",
        "text": [
          " قَالَ أَبُو جَعفَرٍ ع قَالَ رَسُولُ اللّهِ\u001eص السّجُودُ عَلَي سَبعَةِ أَعظُمٍ الجَبهَةِ وَ اليَدَينِ وَ الرّكبَتَينِ وَ الإِبهَامَينِ مِنَ الرّجلَينِ وَ تُرغِمُ بِأَنفِكَ إِرغَاماً أَمّا الفَرضُ فَهَذِهِ السّبعَةُ وَ أَمّا الإِرغَامُ بِالأَنفِ فَسُنّةٌ مِنَ النّبِيّ\u001eص"
        ]
      }
    ]
  },
