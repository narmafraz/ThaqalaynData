    "titles": {
      "ar": "288- بَابُ وُجُوبِ الصّلَاةِ عَلَي كُلّ مَيّتٍ مُسلِمٍ مَقتُولًا كَانَ أَو مَيّتاً حَتفَ أَنفِهِ شَهِيداً كَانَ أَو غَيرَهُ"
    },
    "verse_count": 4,
    "verse_start_index": 1727,
    "verses": [
      {
        "index": 1728,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/13",
              "text": "أَحمَدُ بنُ مُحَمّدِ بنِ عِيسَي"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينِ بنِ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "النّضرِ بنِ سُوَيدٍ عَن هِشَامِ بنِ الحَكَمِ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:266:1",
        "text": [
          " قُلتُ لَهُ شَارِبُ الخَمرِ وَ الزاّنيِ وَ السّارِقُ يُصَلّي عَلَيهِم إِذَا مَاتُوا فَقَالَ نَعَم"
        ]
      },
      {
        "index": 1729,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "سَعدٌ عَن أَيّوبَ بنِ نُوحٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ مَحبُوبٍ عَن اِبرَاهِيمَ بنِ مِهزَمٍ عَن طَلحَةَ بنِ زَيدٍ عَن أَبِي عَبدِ اللّهِ عَن أَبِيهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:266:2",
        "text": [
          " صَلّ عَلَي مَن مَاتَ مِن أَهلِ القِبلَةِ وَ حِسَابُهُ عَلَي اللّهِ"
        ]
      },
      {
        "index": 1730,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن أَحمَدَ بنِ الحَسَنِ بنِ عَلِيّ عَن أَبِي هَمّامٍ إِسمَاعِيلَ بنِ هَمّامٍ عَن مُحَمّدِ بنِ سَعِيدِ بنِ غَزوَانَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "السكّوُنيِ ّ عَن جَعفَرٍ عَن أَبِيهِ عَن آبَائِهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:266:3",
        "text": [
          " قَالَ رَسُولُ اللّهِ\u001eص صَلّوا عَلَي المَرجُومِ مِن أمُتّيِ وَ عَلَي القَتّالِ نَفسَهُ مِن أمُتّيِ لَا تَدَعُوا أَحَداً مِن أمُتّيِ بِلَا صَلَاةٍ"
        ]
      },
      {
        "index": 1731,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي عَن هَارُونَ بنِ مُسلِمٍ عَن مَسعَدَةَ بنِ صَدَقَةَ عَن جَعفَرٍ عَن أَبِيهِ عَن آبَائِهِ أَنّ عَلِيّاً ع لَم يُغَسّل عَمّارَ بنَ يَاسِرٍ رَحِمَهُ اللّهُ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "لَا هَاشِمَ بنَ عُتبَةَ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "هُوَ المِرقَالُ دَفَنَهُمَا بِدِمَائِهِمَا"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "لَم يُصَلّ عَلَيهِمَا فَمَا تَضَمّنَ هَذَا الخَبَرُ مِن أَنّهُ لَم يُصَلّ عَلَيهِمَا وَهمٌ مِنَ الراّويِ لِأَنّا قَد بَيّنّا وُجُوبَ الصّلَاةِ عَلَي كُلّ مَيّتٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "هَذِهِ مَسأَلَةُ إِجمَاعٍ مِنَ الفِرقَةِ المُحِقّةِ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "قَد ذَكَرنَا"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:266:4",
        "text": [
          " أَحكَامِ الشّهَدَاءِ مَا فِيهِ كِفَايَةٌ فِي كِتَابِنَا الكَبِيرِ وَ يَجُوزُ أَن يَكُونَ الوَجهُ فِيهِ حِكَايَةَ مَا يَروِيهِ بَعضُ العَامّةِ عَن أَمِيرِ المُؤمِنِينَ ع فَكَأَنّهُ ع قَالَ إِنّهُم يَروُونَ عَن عَلِيّ ع أَنّهُ لَم يُصَلّ عَلَيهِمَا وَ ذَلِكَ خِلَافُ الحَقّ عَلَي مَا بَيّنّاهُ"
        ]
      }
    ]
  },
