    "titles": {
      "ar": "184- بَابُ الإِقعَاءِ بَينَ السّجدَتَينِ"
    },
    "verse_count": 3,
    "verse_start_index": 1146,
    "verses": [
      {
        "index": 1147,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "أخَبرَنَيِ الشّيخُ رَحِمَهُ اللّهُ عَن أَحمَدَ بنِ مُحَمّدٍ عَن أَبِيهِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الصّفّارِ عَن أَحمَدَ بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحُسَينِ بنِ سَعِيدٍ عَن فَضَالَةَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحُسَينِ بنِ عُثمَانَ عَن سَمَاعَةَ عَن أَبِي بَصِيرٍ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:161:1",
        "text": [
          " لَا تُقعِ بَينَ السّجدَتَينِ إِقعَاءً"
        ]
      },
      {
        "index": 1148,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن حَمّادِ بنِ عُثمَانَ عَن عُبَيدِ اللّهِ الحلَبَيِ ّ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:161:2",
        "text": [
          " لَا بَأسَ بِالإِقعَاءِ فِي الصّلَاةِ فِيمَا بَينَ السّجدَتَينِ فَالوَجهُ فِي هَذِهِ الرّوَايَةِ الرّخصَةُ أَو حَالُ الضّرُورَةِ غَيرَ أَنّ الأَفضَلَ مَا قَدّمنَاهُ فِي الرّوَايَةِ الأُولَي وَ ذَلِكَ أَيضاً مُطَابِقٌ لِلرّوَايَاتِ التّيِ أَورَدنَاهَا فِي كِتَابِنَا الكَبِيرِ وَ يُؤَكّدُ أَيضاً ذَلِكَ"
        ]
      },
      {
        "index": 1149,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ مُعَاوِيَةُ بنُ عَمّارٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/1904",
              "text": "ابنُ مُسلِمٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "الحلَبَيِ ّ جَمِيعاً قَالُوا"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:161:3",
        "text": [
          " لَا تُقعِ بَينَ السّجدَتَينِ كَإِقعَاءِ الكَلبِ"
        ]
      }
    ]
  },
