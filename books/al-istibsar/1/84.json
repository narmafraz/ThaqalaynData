            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحُسَينِ بنِ الحَسَنِ بنِ أَبَانٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينِ بنِ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن غَيرِ وَاحِدٍ مِن أَصحَابِنَا عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:84:1",
        "text": [
          " لَيسَ فِي المذَي ِ مِنَ الشّهوَةِ وَ لَا مِنَ الإِنعَاظِ وَ لَا مِنَ القُبلَةِ وَ لَا مِن مَسّ الفَرجِ وَ لَا مِنَ المُضَاجَعَةِ وُضُوءٌ وَ لَا يُغسَلُ مِنهُ الثّوبُ وَ لَا الجَسَدُ"
        ]
      },
      {
        "index": 531,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدٍ عَن عَلِيّ بنِ الحَكَمِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/216",
              "text": "الحُسَينِ بنِ أَبِي العَلَاءِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:1:84:2",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَنِ المذَي ِ يُصِيبُ الثّوبَ قَالَ إِن عَرَفتَ مَكَانَهُ فَاغسِلهُ فَإِن خفَيِ َ مَكَانُهُ عَلَيكَ فَاغسِلِ الثّوبَ كُلّهُ"
        ]
      },
      {
        "index": 532,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن عَلِيّ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/216",
              "text": "الحُسَينِ بنِ أَبِي العَلَاءِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
