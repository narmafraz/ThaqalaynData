        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُوسَي بنُ القَاسِمِ عَن حَمّادِ بنِ عِيسَي عَن حَرِيزٍ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:74:1",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن مُحرِمٍ غَطّي رَأسَهُ نَاسِياً قَالَ يلُقيِ القِنَاعَ عَن رَأسِهِ وَ يلُبَيّ وَ لَا شَيءَ عَلَيهِ"
        ]
      },
      {
        "index": 2217,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "سَعدُ بنُ عَبدِ اللّهِ عَن أَبِي جَعفَرٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ مَحبُوبٍ عَن عَلِيّ بنِ رِئَابٍ عَن زُرَارَةَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:74:2",
        "text": [
          " قُلتُ لأِبَيِ جَعفَرٍ ع الرّجُلُ المُحرِمُ يُرِيدُ أَن يَنَامَ يغُطَيّ وَجهَهُ مِنَ الذّبَابِ قَالَ نَعَم وَ لَا يُخَمّر رَأسَهُ وَ المَرأَةُ المُحرِمَةُ لَا بَأسَ أَن تغُطَيّ َ وَجهَهَا كُلّهُ"
        ]
      },
      {
        "index": 2218,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُسَعدُ بنُ عَبدِ اللّهِ عَن مُوسَي بنِ الحَسَنِ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ عَلِيّ عَن أَحمَدَ بنِ هِلَالٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/318",
              "text": "مُحَمّدِ بنِ أَبِي عُمَيرٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "أُمَيّةَ بنِ عَلِيّ القيَسيِ ّ عَن عَلِيّ بنِ عَطِيّةَ عَن زُرَارَةَ عَن أَحَدِهِمَا ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:74:3",
        "text": [
          " المُحرِمِ قَالَ لَهُ أَن يغُطَيّ َ رَأسَهُ وَ وَجهَهُ إِذَا أَرَادَ أَن يَنَامَ فَالوَجهُ فِي هَذَا الخَبَرِ أَن نَحمِلَهُ عَلَي حَالِ الِاضطِرَارِ ألّذِي يَخَافُ الإِنسَانُ فِيهَا مِن كَشفِ الرّأسِ الضّرَرَ دُونَ حَالِ الِاختِيَارِ"
        ]
      }
    ]
  },
