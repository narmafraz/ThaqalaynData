    "verse_count": 8,
    "verse_start_index": 1931,
    "verses": [
      {
        "index": 1932,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "أَحمَدُ بنُ مُحَمّدٍ عَن عَلِيّ بنِ الحَكَمِ عَن سُلَيمٍ الفَرّاءِ عَن مُحَمّدِ بنِ مُسلِمٍ عَن أَبِي جَعفَرٍ ع فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:1",
        "text": [
          " الصّائِمِ يَكتَحِلُ فَقَالَ لَا بَأسَ بِهِ لَيسَ بِطَعَامٍ وَ لَا شَرَابٍ"
        ]
      },
      {
        "index": 1933,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "الحُسَينُ بنُ سَعِيدٍ عَن صَفوَانَ بنِ يَحيَي"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحُسَينِ بنِ أَبِي غُندَرٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/126",
              "text": "ابنِ أَبِي يَعفُورٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:2",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن الكُحلِ لِلصّائِمِ قَالَ لَا بَأسَ بِهِ إِنّهُ لَيسَ بِطَعَامٍ يُؤكَلُ"
        ]
      },
      {
        "index": 1934,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/11",
              "text": "عَنهُ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن عَبدِ الحَمِيدِ بنِ أَبِي العَلَاءِ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:3",
        "text": [
          " لَا بَأسَ بِالكُحلِ لِلصّائِمِ"
        ]
      },
      {
        "index": 1935,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ الحُسَينُ بنُ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/63",
              "text": "الحَسَنِ بنِ عَلِيّ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:4",
        "text": [
          " سَأَلتُ أَبَا الحَسَنِ ع عَنِ الصّائِمِ إِذَا اشتَكَي عَينُهُ يَكتَحِلُ بِالذّرُورِ وَ مَا أَشبَهَ ذَلِكَ أَم لَا يَسُوغُ لَهُ ذَلِكَ فَقَالَ لَا يَكتَحِلُ"
        ]
      },
      {
        "index": 1936,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "وَ "
            },
            {
              "kind": "plain",
              "text": "عَنهُ عَن مُحَمّدِ بنِ أَبِي عُمَيرٍ عَن حَمّادِ بنِ عُثمَانَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحلَبَيِ ّ عَن أَبِي عَبدِ اللّهِ ع أَنّهُ سُئِلَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الرّجُلِ يَكتَحِلُ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "هُوَ صَائِمٌ"
            },
            {
              "kind": "plain",
              "text": " فَقَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:5",
        "text": [
          " لَا إنِيّ أَتَخَوّفُ أَن يَدخُلَ رَأسَهُ فَالوَجهُ فِي هَذَينِ الخَبَرَينِ وَ مَا جَرَي مَجرَاهُمَا أَن نَحمِلَهُ عَلَي كُحلٍ فِيهِ مِسكٌ أَو شَيءٌ لَهُ رَائِحَةٌ حَادّةٌ رُبّمَا تَدخُلُ الحَلقَ فَإِنّهُ يُكرَهُ ذَلِكَ يَدُلّ عَلَي ذَلِكَ"
        ]
      },
      {
        "index": 1937,
        "local_index": 6,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ مُحَمّدُ بنُ يَعقُوبَ عَن مُحَمّدِ بنِ يَحيَي عَن أَحمَدَ بنِ مُحَمّدٍ عَن عُثمَانَ بنِ عِيسَي عَن سَمَاعَةَ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:6",
        "text": [
          " سَأَلتُهُ عَنِ الكُحلِ لِلصّائِمِ فَقَالَ إِذَا كَانَ كُحلًا لَيسَ فِيهِ مِسكٌ وَ لَيسَ لَهُ طَعمٌ فِي الحَلقِ فَلَيسَ بِهِ بَأسٌ"
        ]
      },
      {
        "index": 1938,
        "local_index": 7,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "الحُسَينُ بنُ سَعِيدٍ عَن فَضَالَةَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "العَلَاءِ عَن مُحَمّدٍ عَن أَحَدِهِمَا ع أَنّهُ سُئِلَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "المَرأَةِ تَكتَحِلُ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "هيِ َ صَائِمَةٌ"
            },
            {
              "kind": "plain",
              "text": " فَقَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:7",
        "text": [
          " إِذَا لَم يَكُن كُحلًا تَجِدُ لَهُ طَعماً فِي حَلقِهَا فَلَا بَأسَ وَ ألّذِي يَدُلّ عَلَي أَنّ هَذَينِ الخَبَرَينِ وَرَدَا مَورِدَ الكَرَاهِيَةِ دُونَ الحَظرِ"
        ]
      },
      {
        "index": 1939,
        "local_index": 8,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ سَعدُ بنُ عَبدِ اللّهِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ عَلِيّ عَن عَبدِ اللّهِ بنِ المُغِيرَةِ عَن أَبِي دَاوُدَ المُستَرِقّ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/30",
              "text": "صَفوَانَ بنِ يَحيَي"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحُسَينِ بنِ أَبِي غُندَرٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:19:8",
        "text": [
          " قُلتُ لأِبَيِ عَبدِ اللّهِ ع أَكتَحِلُ بِكُحلٍ فِيهِ مِسكٌ وَ أَنَا صَائِمٌ فَقَالَ لَا بَأسَ بِهِ"
        ]
      }
    ]
