              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي نَصرٍ عَن نَجِيحٍ عَن أَبِي الحَسَنِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:58:1",
        "text": [
          " لَا بَأسَ بِلُبسِ الخَاتَمِ لِلمُحرِمِ"
        ]
      },
      {
        "index": 2146,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "الحُسَينُ بنُ سَعِيدٍ عَن مُحَمّدِ بنِ إِسمَاعِيلَ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:58:2",
        "text": [
          " رَأَيتُ العَبدَ الصّالِحَ ع وَ هُوَ مُحرِمٌ وَ عَلَيهِ خَاتَمٌ وَ هُوَ يَطُوفُ طَوَافَ الفَرِيضَةِ قَالَ مُحَمّدُ بنُ الحَسَنِ إِنّمَا يَجُوزُ لُبسُ الخَاتَمِ إِذَا كَانَ القَصدُ بِهِ استِعمَالَ السّنّةِ دُونَ أَن يَكُونَ القَصدُ بِهِ الزّينَةَ يَدُلّ عَلَي هَذَا التّفصِيلِ"
        ]
      },
      {
        "index": 2147,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي عَن اِبرَاهِيمَ بنِ مَهزِيَارَ عَن صَالِحِ بنِ السنّديِ ّ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ مَحبُوبٍ عَن عَلِيّ عَن مِسمَعٍ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:58:3",
        "text": [
          " رَجُلٍ نسَيِ َ أَن يَحلِقَ أَو يُقَصّرَ حَتّي نَفَرَ قَالَ يَحلِقُ إِذَا ذَكَرَ فِي الطّرِيقِ أَو أَينَ كَانَ قَالَ وَ سَأَلتُهُ أَ يَلبَسُ المُحرِمُ الخَاتَمَ قَالَ لَا يَلبَسُهُ لِلزّينَةِ"
        ]
      }
    ]
