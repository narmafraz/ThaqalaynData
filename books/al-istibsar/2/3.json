    "verses": [
      {
        "index": 1824,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "الحُسَينُ بنُ سَعِيدٍ عَن صَفوَانَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/484",
              "text": "العِيصِ بنِ القَاسِمِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:1",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَنِ الفِطرَةِ مَتَي هيِ َ فَقَالَ قَبلَ الصّلَاةِ يَومَ الفِطرِ قُلتُ فَإِن بقَيِ َ مِنهُ شَيءٌ بَعدَ الصّلَاةِ قَالَ لَا بَأسَ نَحنُ نعُطيِ عِيَالَنَا مِنهُ ثُمّ يَبقَي فَنَقسِمُهُ"
        ]
      },
      {
        "index": 1825,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/5",
              "text": "أَحمَدُ بنُ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ عَن أَبِي بَكرٍ الحضَرمَيِ ّ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:2",
        "text": [
          " قَولِ اللّهِ عَزّ وَ جَلّقَد أَفلَحَ مَن تَزَكّي وَ ذَكَرَ اسمَ رَبّهِ فَصَلّي قَالَ يَرُوحُ إِلَي الجَبّانَةِ فيَصُلَيّ"
        ]
      },
      {
        "index": 1826,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن حَمّادِ بنِ عِيسَي عَن مُعَاوِيَةَ بنِ عَمّارٍ عَن اِبرَاهِيمَ بنِ مَيمُونٍ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:3",
        "text": [
          " قَالَ أَبُو عَبدِ اللّهِ ع الفِطرَةُ إِن أَعطَيتَ قَبلَ أَن تَخرُجَ إِلَي العِيدِ فهَيِ َ فِطرَةٌ وَ إِن كَانَ بَعدَ مَا تَخرُجُ إِلَي العِيدِ فهَيِ َ صَدَقَةٌ قَالَ مُحَمّدُ بنُ الحَسَنِ لَا تنَاَفيِ َ بَينَ هَذِهِ الرّوَايَةِ وَ الرّوَايَةِ الأُولَي لِأَنّ الوَجهَ فِي الجَمعِ بَينَهُمَا أَنّهُ يَجِبُ إِخرَاجُ الفِطرَةِ قَبلَ الصّلَاةِ وَ تُعزَلُ فَإِن أَعطَي بَعدَ ذَلِكَ لِلمُستَحِقّ لَم يَكُن بِهِ بَأسٌ"
        ]
      },
      {
        "index": 1827,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "وَ "
            },
            {
              "kind": "plain",
              "text": "كَذَلِكَ الخَبَرُ ألّذِي رَوَاهُ سَعدُ بنُ عَبدِ اللّهِ عَن مُحَمّدِ بنِ الحُسَينِ بنِ أَبِي الخَطّابِ عَن دِينَارِ بنِ حُكَيمٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَارِثِ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:4",
        "text": [
          " لَا بَأسَ بِأَنّ تُؤَخّرَ الفِطرَةُ إِلَي هِلَالِ ذيِ القَعدَةِ فَالوَجهُ فِي هَذَا الخَبَرِ أَيضاً مَا قُلنَاهُ فِي الخَبَرِ الأَوّلِ سَوَاءً وَ ألّذِي يَدُلّ عَلَي مَا قُلنَاهُ"
        ]
      },
      {
        "index": 1828,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ عَلِيّ بنُ الحَسَنِ بنِ فَضّالٍ عَن يَعقُوبَ بنِ يَزِيدَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أَبِي عُمَيرٍ عَن بَعضِ أَصحَابِنَا عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:5",
        "text": [
          " الفِطرَةِ إِذَا عَزَلتَهَا وَ أَنتَ تَطلُبُ بِهَا المَوضِعَ أَو تَنتَظِرُ بِهَا رَجُلًا فَلَا بَأسَ بِهِ"
        ]
      },
      {
        "index": 1829,
        "local_index": 6,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "سَعدٌ عَن مُحَمّدِ بنِ عِيسَي عَن يُونُسَ عَن إِسحَاقَ بنِ عَمّارٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/78",
              "text": "غَيرِهِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:6",
        "text": [
          " سَأَلتُهُ عَنِ الفِطرَةِ قَالَ إِذَا عَزَلتَهَا فَلَا يَضُرّكَ مَتَي أَعطَيتَهَا قَبلَ الصّلَاةِ أَو بَعدَ الصّلَاةِ"
        ]
      },
      {
        "index": 1830,
        "local_index": 7,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُسَعدُ بنُ عَبدِ اللّهِ عَن أَحمَدَ بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينِ بنِ سَعِيدٍ"
            },
