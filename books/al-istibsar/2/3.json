            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "العَبّاسِ بنِ مَعرُوفٍ عَن حَمّادِ بنِ عِيسَي عَن عُمَرَ بنِ أُذَينَةَ عَن زُرَارَةَ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/2937",
              "text": "بُكَيرٍ ابنيَ أَعيَنَ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/155",
              "text": "الفُضَيلِ بنِ يَسَارٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/16",
              "text": "مُحَمّدِ بنِ مُسلِمٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "بُرَيدِ بنِ مُعَاوِيَةَ عَن أَبِي جَعفَرٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "أَبِي عَبدِ اللّهِ ع أَنّهُمَا"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:2:3:7",
        "text": [
          "ا عَلَي الرّجُلِ أَن يعُطيِ َ عَن كُلّ مَن يَعُولُ مِن حُرّ وَ عَبدٍ وَ صَغِيرٍ وَ كَبِيرٍ يعُطيِ يَومَ الفِطرِ قَبلَ الصّلَاةِ فَهُوَ أَفضَلُ وَ هُوَ فِي سَعَةٍ أَن يُعطِيَهَا مِن أَوّلِ يَومٍ يَدخُلُ مِن شَهرِ رَمَضَانَ إِلَي آخِرِهِ فَإِن أَعطَي تَمراً فَصَاعٌ لِكُلّ رَأسٍ وَ إِن لَم يُعطِ تَمراً فَنِصفُ صَاعٍ لِكُلّ رَأسٍ مِن حِنطَةٍ أَو شَعِيرٍ وَ الحِنطَةُ وَ الشّعِيرُ سَوَاءٌ مَا أَجزَأَ عَنهُ الحِنطَةُ فَالشّعِيرُ يجُزيِ فَالوَجهُ فِي هَذَا الخَبَرِ ضَربٌ مِنَ الرّخصَةِ فِي تَقدِيمِ زَكَاةِ الفِطرَةِ قَبلَ حُلُولِ وَقتِهَا كَمَا قُلنَاهُ فِي تَقدِيمِ زَكَاةِ الأَموَالِ وَ إِن كَانَ الفَضلُ إِخرَاجَهَا فِي وَقتِهَا عَلَي مَا صَرّحَ بِهِ ع فِي الخَبَرِ"
        ]
      }
    ]
