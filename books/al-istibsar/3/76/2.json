          },
          {
            "kind": "narrator",
            "path": "/people/narrators/534",
            "text": "بُرَيدِ بنِ مُعَاوِيَةَ العجِليِ ّ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/155",
            "text": "الفُضَيلِ بنِ يَسَارٍ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/1314",
            "text": "إِسمَاعِيلَ الأَزرَقِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مَعمَرِ بنِ يَحيَي بنِ سَالِمٍ كُلّهُم سَمِعَهُ مِن أَبِي جَعفَرٍ ع"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "مِنِ ابنِهِ بَعدَ أَبِيهِ ع بِصِفَةِ مَا قَالُوا"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "إِن لَم أَحفَظ حُرُوفَهُ غَيرَ أَنّهُ لَم يَسقُط جُمَلٌ مَعنَاهُ أَنّ الطّلَاقَ ألّذِي أَمَرَ اللّهُ تَعَالَي بِهِ"
          },
          {
            "kind": "plain",
            "text": " فِي"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/al-istibsar:3:76:2",
      "text": [
        " كِتَابِهِ وَ سُنّةِ نَبِيّهِ\u001eص أَنّهُ إِذَا حَاضَتِ المَرأَةُ وَ طَهُرَت مِن حَيضِهَا أَشهَدَ رَجُلَينِ عَدلَينِ قَبلَ أَن يُجَامِعَهَا عَلَي تَطلِيقَةٍ ثُمّ هُوَ أَحَقّ بِرَجعَتِهَا مَا لَم تَمضِ ثَلَاثَةُ قُرُوءٍ فَإِن رَاجَعَهَا كَانَت عِندَهُ عَلَي تَطلِيقَتَينِ وَ إِن مَضَت ثَلَاثَةُ قُرُوءٍ قَبلَ أَن يُرَاجِعَهَا فهَيِ َ أَملَكُ بِنَفسِهَا فَإِن أَرَادَ أَن يَخطُبَهَا مَعَ الخُطّابِ خَطَبَهَا فَإِن تَزَوّجَهَا كَانَت هيِ َ عِندَهُ عَلَي تَطلِيقَتَينِ وَ مَا خَلَا هَذَا فَلَيسَ بِطَلَاقٍ"
      ]
    }
  },
