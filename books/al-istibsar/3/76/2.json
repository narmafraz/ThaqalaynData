      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "مَا رَوَاهُ الحُسَينُ بنُ سَعِيدٍ عَن حَمّادِ بنِ عِيسَي عَن عُمَرَ بنِ أُذَينَةَ عَن زُرَارَةَ"
