            "text": "بُكَيرٍ ابنيَ أَعيَنَ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "narrator",
            "path": "/people/narrators/16",
            "text": "مُحَمّدِ بنِ مُسلِمٍ"
          },
          {
            "kind": "plain",
