    "verses": [
      {
        "index": 3495,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُحَمّدُ بنُ يَعقُوبَ عَن مُحَمّدِ بنِ يَحيَي عَن أَحمَدَ بنِ مُحَمّدٍ عَن عَلِيّ بنِ الحَكَمِ عَن مُوسَي بنِ بَكرٍ عَن زُرَارَةَ عَن أَبِي جَعفَرٍ ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:104:1",
        "text": [
          " المُطَلّقَةُ ثَلَاثاً لَيسَ لَهَا نَفَقَةٌ عَلَي زَوجِهَا إِنّمَا ذَلِكَ للِتّيِ لِزَوجِهَا عَلَيهَا رَجعَةٌ"
        ]
      },
      {
        "index": 3496,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن حُمَيدِ بنِ زِيَادٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ سَمَاعَةَ عَن مُحَمّدِ بنِ زِيَادٍ عَن عَبدِ اللّهِ بنِ سِنَانٍ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:104:2",
        "text": [
          " سَأَلتُهُ عَنِ المُطَلّقَةِ ثَلَاثاً عَلَي السّنّةِ هَل لَهَا سُكنَي أَو نَفَقَةٌ قَالَ لَا"
        ]
      },
      {
        "index": 3497,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدٍ"
