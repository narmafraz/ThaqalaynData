      "ar": "195- بَابُ عِدّةِ المُختَلِعَةِ"
    },
    "verse_count": 4,
    "verse_start_index": 3504,
    "verses": [
      {
        "index": 3505,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/952",
              "text": "مُحَمّدُ بنُ يَعقُوبَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/20",
              "text": "الحُسَينِ بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/684",
              "text": "المُعَلّي بنِ مُحَمّدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ عَلِيّ عَن أَبَانٍ عَن زُرَارَةَ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:107:1",
        "text": [
          " سَأَلتُ أَبَا جَعفَرٍ ع عَن عِدّةِ المُختَلِعَةِ كَم هيِ َ قَالَ عِدّةُ المُطَلّقَةِ وَ لتَعتَدّ فِي بَيتِهَا وَ المُبَارِئَةُ بِمَنزِلَةِ المُختَلِعَةِ"
        ]
      },
      {
        "index": 3506,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن حُمَيدِ بنِ زِيَادٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "الحَسَنِ بنِ مُحَمّدِ بنِ سَمَاعَةَ عَن دَاوُدَ بنِ سِرحَانَ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:107:2",
        "text": [
          " المُختَلِعَةِ قَالَ عِدّتُهَا عِدّةُ المُطَلّقَةِ وَ تَعتَدّ فِي بَيتِهَا وَ المُختَلِعَةُ بِمَنزِلَةِ المُبَارِئَةِ"
        ]
      },
      {
        "index": 3507,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "سَعدُ بنُ عَبدِ اللّهِ عَن مُحَمّدِ بنِ عِيسَي عَن يُونُسَ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ مُسكَانَ عَن أَبِي بَصِيرٍ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:107:3",
        "text": [
          " عِدّةُ المُبَارِئَةِ وَ المُختَلِعَةِ وَ المُخَيّرَةِ عِدّةُ المُطَلّقَةِ وَ يَعتَدِدنَ فِي بُيُوتِ أَزوَاجِهِنّ"
        ]
      },
      {
        "index": 3508,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ الحَسَنُ بنُ مَحبُوبٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ بُكَيرٍ عَن زُرَارَةَ عَن أَبِي جَعفَرٍ ع أَنّهُ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:107:4",
        "text": [
          " عِدّةُ المُختَلِعَةِ خَمسَةٌ وَ أَربَعُونَ يَوماً فَهَذَا الخَبَرُ يَحتَمِلُ وَجهَينِ أَحَدُهُمَا أَنّهُ إِذَا كَانَتِ المُختَلِعَةُ أَمَةً وَ هيِ َ مِمّن لَا تَحِيضُ وَ مِثلُهَا تَحِيضُ فَعِدّتُهَا خَمسَةٌ وَ أَربَعُونَ يَوماً إِذَا خَلَعَهَا زَوجُهَا وَ الوَجهُ الآخَرُ أَن يَكُونَ الخَبَرُ مَخصُوصاً بِامرَأَةٍ مِن عَادَتِهَا أَن تَحِيضَ فِي هَذِهِ المُدّةِ ثَلَاثَ حِيَضٍ وَ هيِ َ خَمسَةٌ وَ أَربَعُونَ يَوماً وَ عَلَي الوَجهَينِ لَا ينُاَفيِ الأَخبَارَ الأَوّلَةَ"
        ]
      }
    ]
  },
  "index": "al-istibsar:3:107",
