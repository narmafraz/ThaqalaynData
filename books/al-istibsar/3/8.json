        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:8:5",
        "text": [
          " المُتعَةِ قَالَ لَيسَت مِنَ الأَربَعِ لِأَنّهَا لَا تُطَلّقُ وَ لَا تَرِثُ وَ لَا تُوَرّثُ وَ إِنّمَا هيِ َ مُستَأجَرَةٌ وَ قَالَ عِدّتُهَا خَمسٌ وَ أَربَعُونَ لَيلَةً"
        ]
      },
      {
        "index": 2850,
        "local_index": 6,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ مُحَمّدُ بنُ الحَسَنِ الصّفّارُ عَن مُعَاوِيَةَ بنِ حُكَيمٍ عَن عَلِيّ بنِ الحَسَنِ بنِ رِبَاطٍ عَن عَبدِ اللّهِ بنِ مُسكَانَ عَن عَمّارٍ الساّباَطيِ ّ عَن أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "المُتعَةِ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:8:6",
        "text": [
          " هيِ َ أَحَدُ الأَربَعِ"
        ]
      },
      {
        "index": 2851,
        "local_index": 7,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "وَ مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدِ بنِ أَبِي نَصرٍ عَن أَبِي الحَسَنِ ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:8:7",
        "text": [
          " سَأَلتُهُ عَنِ الرّجُلِ يَكُونُ عِندَهُ المَرأَةُ أَ يَحِلّ لَهُ أَن يَتَزَوّجَ بِأُختِهَا مُتعَةً قَالَ لَا قُلتُ حَكَي زُرَارَةُ عَن أَبِي جَعفَرٍ ع إِنّمَا هيِ َ مِثلُ الإِمَاءِ يَتَزَوّجُ مَا شَاءَ قَالَ لَا هيِ َ مِنَ الأَربَعِ فَالوَجهُ فِي هَذَينِ الخَبَرَينِ أَن نَحمِلَهُمَا عَلَي ضَربٍ مِنَ الِاحتِيَاطِ وَ الفَضلِ وَ الأَخبَارَ الأَوّلَةَ عَلَي الجَوَازِ وَ رَفعِ الحَظرِ يَدُلّ عَلَي ذَلِكَ"
        ]
      },
      {
        "index": 2852,
        "local_index": 8,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مَا رَوَاهُ أَحمَدُ بنُ مُحَمّدِ بنِ أَبِي نَصرٍ عَن أَبِي الحَسَنِ الرّضَا ع قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:8:8",
        "text": [
