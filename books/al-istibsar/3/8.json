        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:8:4",
        "text": [
          " ذُكِرَ لَهُ المُتعَةُ أَ هيِ َ مِنَ الأَربَعِ قَالَ تَزَوّج مِنهُنّ أَلفاً فَإِنّهُنّ مُستَأجَرَاتٌ"
        ]
      },
      {
        "index": 2849,
        "local_index": 5,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/4134",
              "text": "مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/277",
              "text": "العَبّاسِ بنِ مَعرُوفٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "القَاسِمِ بنِ عُروَةَ عَن عَبدِ الحَمِيدِ الطاّئيِ ّ عَن مُحَمّدِ بنِ مُسلِمٍ عَن أَبِي جَعفَرٍ ع"
            },
            {
              "kind": "plain",
              "text": " فِي"
            }
          ]
