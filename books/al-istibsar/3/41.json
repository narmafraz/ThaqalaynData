    "verses": [
      {
        "index": 3058,
        "local_index": 1,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "مُحَمّدُ بنُ يَعقُوبَ عَن عَلِيّ بنِ اِبرَاهِيمَ عَن أَبِيهِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/7",
              "text": "ابنِ أَبِي عُمَيرٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "ابنِ أُذَينَةَ عَن بُكَيرِ بنِ أَعيَنَ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "plain",
              "text": "بُرَيدٍ العجِليِ ّ عَن أَبِي جَعفَرٍ"
            },
            {
              "kind": "plain",
              "text": " وَ "
            },
            {
              "kind": "narrator",
              "path": "/people/narrators/669",
              "text": "أَبِي عَبدِ اللّهِ ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:41:1",
        "text": [
          "ا مَنِ اشتَرَي مَملُوكَةً لَهَا زَوجٌ فَإِنّ بَيعَهَا طَلَاقُهَا إِن شَاءَ المشُترَيِ فَرّقَ بَينَهُمَا وَ إِن شَاءَ تَرَكَهُمَا عَلَي نِكَاحِهِمَا"
        ]
      },
      {
        "index": 3059,
        "local_index": 2,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "عَنهُ عَن مُحَمّدِ بنِ يَحيَي عَن أَحمَدَ بنِ مُحَمّدٍ عَن عَلِيّ بنِ الحَكَمِ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "العَلَاءِ عَن مُحَمّدِ بنِ مُسلِمٍ عَن أَحَدِهِمَا ع"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:41:2",
        "text": [
          " طَلَاقُ الأَمَةِ بَيعُهَا أَو بَيعُ زَوجِهَا وَ قَالَ فِي الرّجُلِ يُزَوّجُ أَمَتَهُ رَجُلًا آخَرَ ثُمّ يَبِيعُهَا قَالَ هُوَ فِرَاقُ مَا بَينَهُمَا إِلّا أَن يَشَاءَ المشُترَيِ أَن يَدَعَهُمَا"
        ]
      },
      {
        "index": 3060,
        "local_index": 3,
        "narrator_chain": {
          "parts": [
            {
              "kind": "narrator",
              "path": "/people/narrators/21",
              "text": "الحُسَينُ بنُ سَعِيدٍ"
            },
            {
              "kind": "plain",
              "text": " عَنِ "
            },
            {
              "kind": "plain",
              "text": "القَاسِمِ عَن عَلِيّ عَن أَبِي بَصِيرٍ"
            },
            {
              "kind": "plain",
              "text": " قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:41:3",
        "text": [
          " سَأَلتُ أَبَا عَبدِ اللّهِ ع عَن رَجُلٍ أَنكَحَ أَمَتَهُ حُرّاً أَو عَبدَ قَومٍ آخَرِينَ قَالَ لَيسَ لَهُ أَن يَنزِعَهَا فَإِن بَاعَهَا فَشَاءَ ألّذِي اشتَرَاهَا أَن يَنزِعَهَا مِنَ الرّجُلَ فَعَلَ"
        ]
      },
      {
        "index": 3061,
        "local_index": 4,
        "narrator_chain": {
          "parts": [
            {
              "kind": "plain",
              "text": "فَأَمّا مَا رَوَاهُ مُحَمّدُ بنُ أَحمَدَ بنِ يَحيَي عَن أَيّوبَ بنِ نُوحٍ عَن صَفوَانَ عَن سَالِمٍ أَبِي الفَضلِ عَن عَبدِ الرّحمَنِ بنِ أَبِي عَبدِ اللّهِ قَالَ"
            }
          ]
        },
        "part_type": "Hadith",
        "path": "/books/al-istibsar:3:41:4",
        "text": [
          " قُلتُ لأِبَيِ عَبدِ اللّهِ ع الرّجُلُ يَبتَاعُ الجَارِيَةَ وَ لَهَا زَوجٌ حُرّ قَالَ لَا يَحِلّ لِأَحَدٍ أَن يَمَسّهَا حَتّي يُطَلّقَهَا زَوجُهَا الحُرّ فَالوَجهُ فِي هَذَا الخَبَرِ أَن نَحمِلَهُ عَلَي أَنّهُ إِذَا رضَيِ َ بِذَلِكَ المشُترَيِ لَم يَحِلّ لِأَحَدٍ حَتّي يُطَلّقَهَا الحُرّ عَلَي مَا فُصّلَ فِي الأَخبَارِ المُتَقَدّمَةِ"
        ]
      }
    ]
  },
