        ],
        "translations": {
          "en.sayed-athar-husain-rizvi-&-sayed-maqsood-athar": [
            "2.  It is narrated that Allah does not take away one or both the eyes of a person except that He frees that person from being questioned about sins."
          ]
        }
      }
