    "verse": {
      "index": 4,
      "local_index": 3,
      "narrator_chain": {
        "parts": [
          {
            "kind": "plain",
            "text": "وَأَمَّا حَقُّ اللّسَان فَإكْرَامُهُ"
          },
          {
            "kind": "plain",
            "text": " عَنِ "
          },
          {
            "kind": "plain",
            "text": "الْخَنَى وتَعْوِيدُهُ الْخَيْرِ"
          },
          {
            "kind": "plain",
            "text": " وَ "
          },
          {
            "kind": "plain",
            "text": "تَرك الْفُضُول الَّتي لا فائِدَةِ لَها و البِرُّ بالنَّاسِ و حُسْن القَولِ في"
          }
        ]
      },
      "part_type": "Hadith",
      "path": "/books/risalat-al-huquq:2:3",
      "source_url": "https://thaqalayn.net/hadith/33/1/2/3",
      "text": [
        "هم."
      ],
      "translations": {
        "en.william-c-chittick": [
          "The right of the tongue is that you consider it too noble for obscenity, accustom it to good, refrain from any meddling in which there is nothing to be gained, express kindness to the people, and speak well concerning them."
        ]
      }
    },
